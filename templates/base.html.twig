<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}FarmAI - Système de Gestion{% endblock %}</title>
        
        {# Favicon standard Symfony avec une touche FarmAI (icône verte) #}
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🌿</text></svg>">
        
        {# Import des icônes FontAwesome pour tout le projet #}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

        {% block stylesheets %}
            {# Les fichiers CSS globaux peuvent être ajoutés ici #}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {# Ce bloc sera remplacé par le contenu de tes autres fichiers (ex: login ou layouts) #}
        {% block body %}{% endblock %}
    </body>
</html>