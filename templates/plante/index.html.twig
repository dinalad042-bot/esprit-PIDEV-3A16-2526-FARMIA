{% extends 'layouts/agricole.html.twig' %}

{% block title %}Gestion des Plantes - FarmAI{% endblock %}

{% block body %}
<div style="background-color: #f8fafc; min-height: 100vh; padding: 20px; font-family: 'Segoe UI', sans-serif;">
    
    <div style="margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 style="color: #1e293b; font-size: 2rem; font-weight: 800; margin: 0;">Gestion des Plantes</h1>
            <p style="color: #64748b; margin: 5px 0 0 0;">Suivez vos cultures et gérez vos stocks.</p>
        </div>
        <div style="display: flex; align-items: center; gap: 20px;">
            <a href="#" style="background-color: #dc2626; color: white; text-decoration: none; padding: 10px 20px; border-radius: 12px; display: flex; align-items: center; gap: 10px; font-weight: 700;">
                <i class="fa-solid fa-file-pdf"></i> PDF
            </a>
            <a href="{{ path('app_exploitation_menu') }}" style="text-decoration: none; color: #2d7a36; font-weight: 600;">
                <i class="fa-solid fa-arrow-left"></i> Retour Menu
            </a>
        </div>
    </div>

    <div style="display: flex; gap: 30px; align-items: flex-start;">
        
        {# FORMULAIRE #}
        <div style="flex: 0 0 400px; background: white; border-radius: 20px; padding: 30px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <h2 style="color: #1e293b; font-size: 1.3rem; font-weight: 700; margin-bottom: 25px;">
                {{ plante_edit ? 'Modifier la plante' : 'Nouvelle Plante' }}
            </h2>
            
            {% set action_url = plante_edit ? path('app_plante_update', {'id_plante': plante_edit.idPlante}) : path('app_plante_new') %}
            
            {# NOVALIDATE désactive le contrôle navigateur #}
            <form action="{{ action_url }}" method="POST" novalidate>
                
                {# Champ Espèce #}
                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: 600; margin-bottom: 8px;">Nom de l'espèce</label>
                    <input type="text" name="nom_espece" value="{{ plante_edit ? plante_edit.nomEspece : '' }}" 
                           style="width: 100%; padding: 12px; border: 1px solid {{ errors.nom_espece is defined ? '#dc2626' : '#e2e8f0' }}; border-radius: 12px;">
                    {% if errors.nom_espece is defined %}
                        <small style="color: #dc2626; font-weight: 600; margin-top: 5px; display: block;">{{ errors.nom_espece }}</small>
                    {% endif %}
                </div>

                {# Champ Cycle #}
                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: 600; margin-bottom: 8px;">Cycle de vie</label>
                    <input type="text" name="cycle_vie" value="{{ plante_edit ? plante_edit.cycleVie : '' }}" 
                           style="width: 100%; padding: 12px; border: 1px solid {{ errors.cycle_vie is defined ? '#dc2626' : '#e2e8f0' }}; border-radius: 12px;">
                    {% if errors.cycle_vie is defined %}
                        <small style="color: #dc2626; font-weight: 600; margin-top: 5px; display: block;">{{ errors.cycle_vie }}</small>
                    {% endif %}
                </div>

                {# Champ Quantité #}
                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: 600; margin-bottom: 8px;">Quantité</label>
                    <input type="number" name="quantite" value="{{ plante_edit ? plante_edit.quantite : '' }}" 
                           style="width: 100%; padding: 12px; border: 1px solid {{ errors.quantite is defined ? '#dc2626' : '#e2e8f0' }}; border-radius: 12px;">
                    {% if errors.quantite is defined %}
                        <small style="color: #dc2626; font-weight: 600; margin-top: 5px; display: block;">{{ errors.quantite }}</small>
                    {% endif %}
                </div>

                {# Champ Ferme #}
                <div style="margin-bottom: 30px;">
                    <label style="display: block; font-weight: 600; margin-bottom: 8px;">Ferme d'affectation</label>
                    <select name="id_ferme" style="width: 100%; padding: 12px; border: 1px solid {{ errors.id_ferme is defined ? '#dc2626' : '#e2e8f0' }}; border-radius: 12px; background: white;">
                        <option value="">Choisir une ferme...</option>
                        {% for ferme in fermes %}
                            <option value="{{ ferme.idFerme }}" {{ (plante_edit and plante_edit.idFerme == ferme.idFerme) ? 'selected' : '' }}>
                                {{ ferme.nomFerme }}
                            </option>
                        {% endfor %}
                    </select>
                    {% if errors.id_ferme is defined %}
                        <small style="color: #dc2626; font-weight: 600; margin-top: 5px; display: block;">{{ errors.id_ferme }}</small>
                    {% endif %}
                </div>

                <button type="submit" style="width: 100%; background: #2d7a36; color: white; border: none; padding: 14px; border-radius: 10px; font-weight: 700; cursor: pointer;">
                    {{ plante_edit ? 'Mettre à jour' : 'Enregistrer la plante' }}
                </button>
            </form>
        </div>

        {# TABLEAU #}
        <div style="flex: 1;">
            <div style="background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                <table style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead style="background: #f1f5f9;">
                        <tr>
                            <th style="padding: 15px;">Espèce</th>
                            <th style="padding: 15px;">Cycle</th>
                            <th style="padding: 15px;">Quantité</th>
                            <th style="padding: 15px;">Ferme</th>
                            <th style="padding: 15px; text-align: center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for plante in plantes %}
                            <tr style="border-bottom: 1px solid #f1f5f9;">
                                <td style="padding: 15px; font-weight: 600;">{{ plante.nomEspece }}</td>
                                <td style="padding: 15px;">{{ plante.cycleVie }}</td>
                                <td style="padding: 15px;">{{ plante.quantite }}</td>
                                <td style="padding: 15px;">
                                    {% set ferme_nom = 'Non affectée' %}
                                    {% for f in fermes %}{% if f.idFerme == plante.idFerme %}{% set ferme_nom = f.nomFerme %}{% endif %}{% endfor %}
                                    {{ ferme_nom }}
                                </td>
                                <td style="padding: 15px; text-align: center; display: flex; gap: 8px; justify-content: center;">
                                    <a href="{{ path('app_plante_edit', {'id_plante': plante.idPlante}) }}" style="color: #2d7a36; background: #f0fdf4; padding: 8px; border-radius: 6px;"><i class="fa-solid fa-pen"></i></a>
                                    <form method="post" action="{{ path('app_plante_delete', {'id_plante': plante.idPlante}) }}" onsubmit="return confirm('Supprimer ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ plante.idPlante) }}">
                                        <button style="color: #dc2626; background: #fef2f2; border: none; padding: 8px; border-radius: 6px; cursor: pointer;"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}