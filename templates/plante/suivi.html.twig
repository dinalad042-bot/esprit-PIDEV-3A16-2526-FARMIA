{% extends 'layouts/agricole.html.twig' %}

{% block title %}Suivi Culture - {{ plante.nom }}{% endblock %}

{% block body %}
<style>
    /* --- STYLE CALENDRIER --- */
    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 10px;
        background: #f8fafc;
        padding: 20px;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }
    .calendar-day {
        aspect-ratio: 1;
        background: white;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid #f1f5f9;
        position: relative;
    }
    .calendar-day:hover { transform: scale(1.05); border-color: #059669; }
    
    .day-watered { background: #e0f2fe; border-color: #0ea5e9; color: #0369a1; }
    .day-watered::after {
        content: '\f043'; font-family: 'Font Awesome 6 Free'; font-weight: 900;
        font-size: 0.7rem; position: absolute; top: 5px; right: 5px;
    }

    .today { border: 2px solid #059669 !important; box-shadow: 0 0 10px rgba(5, 150, 105, 0.2); }

    /* --- PRINT PDF (SANS DASHBOARD) --- */
    @media print {
        header, nav, .sidebar, .navbar, .no-print { display: none !important; }
        body { background: white !important; margin: 0; padding: 0; visibility: hidden; }
        .printable-area { 
            visibility: visible; 
            position: absolute; 
            left: 0; 
            top: 0; 
            width: 100% !important; 
            margin: 0 !important; 
            padding: 20px !important; 
            box-shadow: none !important;
        }
    }
</style>

<div style="max-width: 1100px; margin: 40px auto; padding: 0 20px;">
    
    {# Actions rapides #}
    <div class="no-print" style="display: flex; justify-content: space-between; margin-bottom: 25px;">
        <a href="{{ path('app_plante_index') }}" style="text-decoration: none; color: #64748b; font-weight: 700;">
            <i class="fa-solid fa-arrow-left"></i> Retour aux cultures
        </a>
        <button onclick="window.print()" style="background: #1e293b; color: white; border: none; padding: 10px 20px; border-radius: 10px; cursor: pointer; font-weight: 700;">
            <i class="fa-solid fa-print"></i> Imprimer le carnet de suivi
        </button>
    </div>

    <div class="printable-area" style="background: white; border-radius: 24px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
        
        {# Header de la Plante #}
        <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 40px; border-bottom: 2px solid #f1f5f9; padding-bottom: 20px;">
            <div style="width: 80px; height: 80px; background: #ecfdf5; border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 2rem;">
                🌱
            </div>
            <div>
                <h1 style="margin: 0; color: #1e293b; font-size: 2rem;">{{ plante.nom }} <span style="font-weight: 400; color: #94a3b8;">#{{ plante.id }}</span></h1>
                <p style="margin: 5px 0 0 0; color: #64748b;">Parcelle : <b>{{ plante.ferme.nomFerme }}</b> | Mise en terre : {{ plante.datePlantation|date('d M Y') }}</p>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 30px;">
            
            {# --- SECTION 1 : CALENDRIER D'ARROSAGE DYNAMIQUE --- #}
            <div>
                <h3 style="margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                    <i class="fa-solid fa-calendar-check" style="color: #0ea5e9;"></i> Historique d'Arrosage
                </h3>
                
                {# Préparation des dates arrosées #}
                {% set datesArrosage = [] %}
                {% for a in plante.arrosages %}
                    {% set datesArrosage = datesArrosage|merge([a.dateArrosage|date('Y-m-d')]) %}
                {% endfor %}

                <div class="calendar-grid">
                    {% set yearMonth = "now"|date("Y-m-") %}
                    {% for day in 1..30 %}
                        {% set currentIterationDate = yearMonth ~ (day < 10 ? '0' ~ day : day) %}
                        {% set isWatered = currentIterationDate in datesArrosage %}
                        
                        <div class="calendar-day {{ isWatered ? 'day-watered' : '' }} {{ day == "now"|date("d") ? 'today' : '' }}" 
                             onclick="toggleWatering({{ plante.id }}, '{{ currentIterationDate }}', this)">
                            <span style="font-size: 0.7rem; opacity: 0.5;">{{ "now"|date("M") }}</span>
                            {{ day }}
                        </div>
                    {% endfor %}
                </div>
                <p style="font-size: 0.85rem; color: #64748b; margin-top: 15px;">
                    <i class="fa-solid fa-circle-info"></i> Cliquez sur un jour pour valider ou annuler un arrosage.
                </p>
            </div>

            {# --- SECTION 2 : ÉTAT & RÉCOLTE --- #}
            <div style="display: flex; flex-direction: column; gap: 20px;">
                
                {# Bloc Récolte #}
                <div style="background: #fffbeb; padding: 25px; border-radius: 20px; border: 1px solid #fef3c7;">
                    <h4 style="margin: 0 0 15px 0; color: #92400e; display: flex; align-items: center; gap: 10px;">
                        <i class="fa-solid fa-basket-shopping"></i> Action de Récolte
                    </h4>
                    <p style="font-size: 0.9rem; color: #b45309; margin-bottom: 20px;">
                        Marquer la fin de vie de la plante pour archiver ce cycle.
                    </p>
                    <button onclick="markHarvested({{ plante.id }})" style="width: 100%; background: #d97706; color: white; border: none; padding: 12px; border-radius: 10px; font-weight: 700; cursor: pointer;">
                        Déclarer Récoltée
                    </button>
                </div>

                {# Bloc Stats #}
                <div style="background: #f8fafc; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0;">
                    <h4 style="margin: 0 0 10px 0; color: #1e293b;">Résumé du cycle</h4>
                    <div style="display: flex; justify-content: space-between; font-size: 0.9rem; padding: 8px 0; border-bottom: 1px solid #f1f5f9;">
                        <span>Arrosages totaux</span>
                        <b id="water-count">{{ plante.arrosages|length }}</b>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.9rem; padding: 8px 0;">
                        <span>Jours depuis plantation</span>
                        <b>{{ date(plante.datePlantation).diff(date("now")).days }} jours</b>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    async function toggleWatering(planteId, date, element) {
        try {
            const response = await fetch(`/api/plante/${planteId}/arrosage/${date}`, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            if (response.ok) {
                element.classList.toggle('day-watered');
                const countElem = document.getElementById('water-count');
                let currentCount = parseInt(countElem.innerText);
                countElem.innerText = element.classList.contains('day-watered') ? currentCount + 1 : currentCount - 1;
            }
        } catch (error) {
            console.error("Erreur API:", error);
        }
    }

    async function markHarvested(planteId) {
        if (!confirm("Marquer comme récoltée ?")) return;
        try {
            const response = await fetch(`/api/plante/${planteId}/recolte`, {
                method: 'PATCH'
            });
            if (response.ok) {
                window.location.reload();
            }
        } catch (error) {
            console.error("Erreur API Récolte:", error);
        }
    }
</script>
{% endblock %}