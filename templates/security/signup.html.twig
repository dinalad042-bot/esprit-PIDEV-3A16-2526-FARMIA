{% extends 'layouts/auth.html.twig' %}

{% block title %}Inscription - FarmAI{% endblock %}

{% block left_subtitle %}Rejoignez-nous{% endblock %}

{% block left_features %}
    <li>Inscription rapide et sécurisée</li>
    <li>Accès à tous les outils</li>
    <li>Support dédié</li>
{% endblock %}

{% block auth_content %}
    {% if error is defined and error %}
        <div class="alert alert-error">
            <i class="fas fa-exclamation-triangle"></i>
            <span>{{ error }}</span>
        </div>
    {% endif %}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        <div class="form-group row">
            <div>
                <label for="{{ form.nom.vars.id }}">Nom *</label>
                {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Votre nom'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.nom) }}</div>
            </div>
            <div>
                <label for="{{ form.prenom.vars.id }}">Prénom *</label>
                {{ form_widget(form.prenom, {'attr': {'class': 'form-control', 'placeholder': 'Votre prénom'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.prenom) }}</div>
            </div>
        </div>

        <div class="form-group">
            <label for="{{ form.email.vars.id }}">Email *</label>
            {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'exemple@email.com'}}) }}
            <div class="field-error-wrapper">{{ form_errors(form.email) }}</div>
        </div>

        <div class="form-group row">
            <div>
                <label for="{{ form.cin.vars.id }}">CIN *</label>
                {{ form_widget(form.cin, {'attr': {'class': 'form-control', 'placeholder': '8 caractères'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.cin) }}</div>
            </div>
            <div>
                <label for="{{ form.telephone.vars.id }}">Téléphone *</label>
                {{ form_widget(form.telephone, {'attr': {'class': 'form-control', 'placeholder': 'XX XXX XXX'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.telephone) }}</div>
            </div>
        </div>

        <div class="form-group" style="position: relative;">
            <label for="{{ form.adresse.vars.id }}">Adresse *</label>
            {{ form_widget(form.adresse, {'attr': {'class': 'form-control', 'placeholder': 'Commencez à taper votre agglomération/ville...', 'autocomplete': 'off'}}) }}
            <!-- Container du loader -->
            <div id="address-loader" style="display: none; position: absolute; right: 10px; top: 40px; color: var(--accent-green);">
                <i class="fas fa-spinner fa-spin"></i>
            </div>
            <!-- Menu déroulant (dropdown) des suggestions -->
            <ul id="address-suggestions" class="dropdown-menu" style="display: none; position: absolute; w..."></ul>
            <div class="field-error-wrapper">{{ form_errors(form.adresse) }}</div>
        </div>
        
        <!-- Render hidden fields -->
        {{ form_widget(form.latitude) }}
        {{ form_widget(form.longitude) }}

        <div class="form-group row">
            <div>
                <label for="{{ form.password.first.vars.id }}">Mot de passe *</label>
                {{ form_widget(form.password.first, {'attr': {'class': 'form-control', 'placeholder': 'Min. 6 caractères'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.password.first) }}</div>
            </div>
            <div>
                <label for="{{ form.password.second.vars.id }}">Confirmer *</label>
                {{ form_widget(form.password.second, {'attr': {'class': 'form-control', 'placeholder': 'Confirmer'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.password.second) }}</div>
            </div>
        </div>
        {# Handle global RepeatedType invalid_message (e.g. passwords don't match) #}
        {% if form.password.vars.errors|length > 0 %}
            <div class="field-error-wrapper">{{ form_errors(form.password) }}</div>
        {% endif %}

        <div class="form-group">
            <label for="{{ form.role.vars.id }}">Rôle *</label>
            {{ form_widget(form.role, {'attr': {'class': 'form-control'}}) }}
            <div class="field-error-wrapper">{{ form_errors(form.role) }}</div>
        </div>

        <div class="checkbox-group">
            {{ form_widget(form.agreeTerms) }}
            <label for="{{ form.agreeTerms.vars.id }}">J'accepte les conditions d'utilisation</label>
        </div>
        <div class="field-error-wrapper" style="margin-bottom: 12px;">{{ form_errors(form.agreeTerms) }}</div>

        <!-- Bouton Signup vert plain -->
        <button class="btn btn-login" type="submit" style="width: 100%;">S'inscrire</button>
    {{ form_end(form) }}
    
    <div class="auth-links">
        Déjà inscrit ? <a href="{{ path('app_login') }}">Se connecter</a>
    </div>
{% endblock %}

{% block scripts %}
<style>
    #address-suggestions {
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        z-index: 1000;
        background: rgba(20, 20, 20, 0.95);
        border: 1px solid rgba(46, 213, 115, 0.3);
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        list-style: none;
        padding: 0;
        margin: 5px 0 0 0;
        max-height: 250px;
        overflow-y: auto;
    }
    #address-suggestions li {
        padding: 10px 15px;
        cursor: pointer;
        color: white;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        transition: background 0.2s;
        display: flex;
        align-items: center;
    }
    #address-suggestions li:last-child {
        border-bottom: none;
    }
    #address-suggestions li.active, #address-suggestions li:hover {
        background: rgba(46, 213, 115, 0.2);
    }
    #address-suggestions li i {
        color: var(--accent-green);
        margin-right: 10px;
    }
    .suggestion-text {
        display: flex;
        flex-direction: column;
    }
    .suggestion-main {
        font-weight: 500;
        font-size: 0.95rem;
    }
    .suggestion-sub {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.6);
    }
    .no-results {
        padding: 10px 15px;
        color: rgba(255, 255, 255, 0.6);
        text-align: center;
        font-style: italic;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const addressInput = document.getElementById("{{ form.adresse.vars.id }}");
        const latInput = document.getElementById("{{ form.latitude.vars.id }}");
        const lonInput = document.getElementById("{{ form.longitude.vars.id }}");
        const dropdown = document.getElementById("address-suggestions");
        const loader = document.getElementById("address-loader");

        let debounceTimer;
        let currentFocus = -1;

        // Fonction fetch vers API Photon
        async function fetchAddresses(query) {
            try {
                loader.style.display = 'block';
                const response = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(query)}&limit=5`);
                if (!response.ok) throw new Error("Erreur réseau");
                const data = await response.json();
                renderSuggestions(data.features || []);
            } catch (error) {
                console.error("Erreur d'autocomplétion :", error);
                dropdown.innerHTML = '<li class="no-results">Erreur de chargement.</li>';
                dropdown.style.display = 'block';
            } finally {
                loader.style.display = 'none';
            }
        }

        // Rendu des suggestions dans le DOM
        function renderSuggestions(features) {
            dropdown.innerHTML = '';
            currentFocus = -1;

            if (features.length === 0) {
                dropdown.innerHTML = '<li class="no-results">Aucune adresse trouvée</li>';
                dropdown.style.display = 'block';
                return;
            }

            features.forEach((feature, index) => {
                const props = feature.properties;
                const geom = feature.geometry;

                const li = document.createElement("li");
                
                // Formater l'affichage
                const mainText = props.name || props.street || props.city;
                let subTextParts = [];
                if (props.postcode) subTextParts.push(props.postcode);
                if (props.city && props.city !== mainText) subTextParts.push(props.city);
                if (props.country) subTextParts.push(props.country);
                const subText = subTextParts.join(', ');

                li.innerHTML = `
                    <i class="fas fa-map-marker-alt"></i>
                    <div class="suggestion-text">
                        <span class="suggestion-main">${mainText}</span>
                        <span class="suggestion-sub">${subText}</span>
                    </div>
                `;

                // Clic sur une suggestion
                li.addEventListener("click", function() {
                    const fullAddress = `${mainText}${subText ? ', ' + subText : ''}`;
                    addressInput.value = fullAddress;
                    latInput.value = geom.coordinates[1]; // lat
                    lonInput.value = geom.coordinates[0]; // lon
                    dropdown.style.display = 'none';
                });

                dropdown.appendChild(li);
            });

            dropdown.style.display = 'block';
        }

        // Événement de saisie au clavier avec Debounce (300ms)
        addressInput.addEventListener("input", function() {
            clearTimeout(debounceTimer);
            const query = this.value.trim();

            if (query.length < 3) {
                dropdown.style.display = 'none';
                latInput.value = "";
                lonInput.value = "";
                return;
            }

            debounceTimer = setTimeout(() => {
                fetchAddresses(query);
            }, 300);
        });

        // Navigation au clavier dans les résultats
        addressInput.addEventListener("keydown", function(e) {
            const items = dropdown.getElementsByTagName("li");
            if (dropdown.style.display === 'none' || typeof items === "undefined" || items.length === 0) return;

            if (e.key === "ArrowDown") {
                e.preventDefault();
                currentFocus++;
                addActive(items);
            } else if (e.key === "ArrowUp") {
                e.preventDefault();
                currentFocus--;
                addActive(items);
            } else if (e.key === "Enter") {
                if (currentFocus > -1) {
                    e.preventDefault(); // Protège la soumission du formulaire
                    items[currentFocus].click();
                }
            }
        });

        function addActive(items) {
            if (!items) return false;
            removeActive(items);
            if (currentFocus >= items.length) currentFocus = 0;
            if (currentFocus < 0) currentFocus = (items.length - 1);
            if (items[currentFocus]) {
                items[currentFocus].classList.add("active");
                // Scroll au focus
                items[currentFocus].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        }

        function removeActive(items) {
            for (let i = 0; i < items.length; i++) {
                items[i].classList.remove("active");
            }
        }

        // Fermer le menu si clic à l'extérieur
        document.addEventListener("click", function (e) {
            if (e.target !== addressInput && e.target !== dropdown && !dropdown.contains(e.target)) {
                dropdown.style.display = 'none';
            }
        });
    });
</script>
{% endblock %}
