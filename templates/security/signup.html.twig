{% extends 'layouts/auth.html.twig' %}

{% block title %}Inscription - FarmAI{% endblock %}

{% block left_subtitle %}Rejoignez-nous{% endblock %}

{% block left_features %}
    <li>Inscription rapide et sécurisée</li>
    <li>Accès à tous les outils</li>
    <li>Support dédié</li>
{% endblock %}

{% block auth_content %}
    {% if error is defined and error %}
        <div class="alert alert-error">
            <i class="fas fa-exclamation-triangle"></i>
            <span>{{ error }}</span>
        </div>
    {% endif %}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        <div class="form-group row">
            <div>
                <label for="{{ form.nom.vars.id }}">Nom *</label>
                {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Votre nom'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.nom) }}</div>
            </div>
            <div>
                <label for="{{ form.prenom.vars.id }}">Prénom *</label>
                {{ form_widget(form.prenom, {'attr': {'class': 'form-control', 'placeholder': 'Votre prénom'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.prenom) }}</div>
            </div>
        </div>

        <div class="form-group">
            <label for="{{ form.email.vars.id }}">Email *</label>
            {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'exemple@email.com'}}) }}
            <div class="field-error-wrapper">{{ form_errors(form.email) }}</div>
        </div>

        <div class="form-group row">
            <div>
                <label for="{{ form.cin.vars.id }}">CIN *</label>
                {{ form_widget(form.cin, {'attr': {'class': 'form-control', 'placeholder': '8 caractères'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.cin) }}</div>
            </div>
            <div>
                <label for="{{ form.telephone.vars.id }}">Téléphone *</label>
                {{ form_widget(form.telephone, {'attr': {'class': 'form-control', 'placeholder': 'XX XXX XXX'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.telephone) }}</div>
            </div>
        </div>

        <div class="form-group">
            <label for="{{ form.adresse.vars.id }}">Adresse *</label>
            {{ form_widget(form.adresse, {'attr': {'class': 'form-control', 'placeholder': 'Votre adresse complète'}}) }}
            <div class="field-error-wrapper">{{ form_errors(form.adresse) }}</div>
        </div>

        <div class="form-group row">
            <div>
                <label for="{{ form.password.first.vars.id }}">Mot de passe *</label>
                {{ form_widget(form.password.first, {'attr': {'class': 'form-control', 'placeholder': 'Min. 6 caractères'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.password.first) }}</div>
            </div>
            <div>
                <label for="{{ form.password.second.vars.id }}">Confirmer *</label>
                {{ form_widget(form.password.second, {'attr': {'class': 'form-control', 'placeholder': 'Confirmer'}}) }}
                <div class="field-error-wrapper">{{ form_errors(form.password.second) }}</div>
            </div>
        </div>
        {# Handle global RepeatedType invalid_message (e.g. passwords don't match) #}
        {% if form.password.vars.errors|length > 0 %}
            <div class="field-error-wrapper">{{ form_errors(form.password) }}</div>
        {% endif %}

        <div class="form-group">
            <label for="{{ form.role.vars.id }}">Rôle *</label>
            {{ form_widget(form.role, {'attr': {'class': 'form-control'}}) }}
            <div class="field-error-wrapper">{{ form_errors(form.role) }}</div>
        </div>

        <div class="checkbox-group">
            {{ form_widget(form.agreeTerms) }}
            <label for="{{ form.agreeTerms.vars.id }}">J'accepte les conditions d'utilisation</label>
        </div>
        <div class="field-error-wrapper" style="margin-bottom: 12px;">{{ form_errors(form.agreeTerms) }}</div>

        <!-- Bouton Signup vert plain -->
        <button class="btn btn-primary" type="submit">S'inscrire</button>
    {{ form_end(form) }}
    
    <div class="auth-links">
        Déjà inscrit ? <a href="{{ path('app_login') }}">Se connecter</a>
    </div>
{% endblock %}
