{% extends 'layouts/auth.html.twig' %}

{% block title %}Mot de passe oublié - FarmIA{% endblock %}

{% block left_subtitle %}Récupération de compte{% endblock %}

{% block left_features %}
    <li>Sécurité garantie</li>
    <li>Réinitialisation rapide</li>
    <li>Support 24/7</li>
{% endblock %}

{% block auth_content %}
    <div style="text-align: center; margin-bottom: 30px;">
        <i class="fa-solid fa-lock" style="font-size: 3rem; color: var(--accent-green); margin-bottom: 15px;"></i>
        <h3 style="color: white; font-weight: 600; margin-bottom: 10px;">Mot de passe oublié ?</h3>
        <p style="color: rgba(255,255,255,0.7); font-size: 0.9rem; line-height: 1.5;">
            Entrez votre adresse email et nous vous enverrons un code à 6 chiffres pour réinitialiser votre mot de passe.
        </p>
    </div>

    <!-- Les flashes d'erreur et succès sont gérés par le layout parent -->

    <form method="post" action="{{ path('app_forgot_password') }}">
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" name="email" id="email" class="form-control" placeholder="exemple@email.com" required autofocus>
        </div>

        <button class="btn btn-login" type="submit" style="margin-top: 10px;">Envoyer le code</button>
    </form>
    
    <div class="auth-links" style="margin-top: 25px;">
        <a href="{{ path('app_login') }}"><i class="fa-solid fa-arrow-left me-1"></i> Retour à la connexion</a>
    </div>
{% endblock %}
