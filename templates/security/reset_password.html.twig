{% extends 'layouts/auth.html.twig' %}

{% block title %}Réinitialisation du mot de passe - FarmIA{% endblock %}

{% block left_subtitle %}Création du mot de passe{% endblock %}

{% block left_features %}
    <li>Chiffrement de bout en bout</li>
    <li>Mot de passe sécurisé</li>
    <li>Accès instantané</li>
{% endblock %}

{% block auth_content %}
    <div style="text-align: center; margin-bottom: 30px;">
        <i class="fa-solid fa-key" style="font-size: 3rem; color: var(--accent-green); margin-bottom: 15px;"></i>
        <h3 style="color: white; font-weight: 600; margin-bottom: 10px;">Nouveau mot de passe</h3>
        <p style="color: rgba(255,255,255,0.7); font-size: 0.9rem; line-height: 1.5;">
            Un code à 6 chiffres a été envoyé à <strong>{{ email }}</strong>. Entrez-le ci-dessous pour créer un nouveau mot de passe.
        </p>
    </div>

    <!-- Les flashes d'erreur et succès sont gérés par le layout parent -->

    <form method="post" action="{{ path('app_reset_password_verify') }}">
        <!-- Hidden email field to track the user -->
        <input type="hidden" name="email" value="{{ email }}">

        <div class="form-group">
            <label for="code">Code à 6 chiffres</label>
            <input type="text" name="code" id="code" class="form-control" placeholder="123456" maxlength="6" pattern="\d{6}" required autofocus style="letter-spacing: 5px; text-align: center; font-size: 1.2rem; font-weight: bold;">
        </div>

        <div class="form-group">
            <label for="new_password">Nouveau mot de passe</label>
            <input type="password" name="new_password" id="new_password" class="form-control" placeholder="Entrez le nouveau mot de passe" required>
        </div>

        <div class="form-group">
            <label for="confirm_password">Confirmez le mot de passe</label>
            <input type="password" name="confirm_password" id="confirm_password" class="form-control" placeholder="Retapez votre mot de passe" required>
        </div>

        <button class="btn btn-login" type="submit" style="margin-top: 10px;">Réinitialiser</button>
    </form>
{% endblock %}
