{% extends 'layouts/admin.html.twig' %}

{% block title %}Audit des Actions - FarmAI{% endblock %}

{% block body %}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h1 class="page-title" style="margin: 0;">Audit des Actions Utilisateurs</h1>
        <div style="display: flex; gap: 12px;">
            <a href="{{ path('dashboard_default') }}" class="btn btn-outline-dark"><i class="fas fa-arrow-left"></i> Retour</a>
            <a href="{{ path('user_log_index') }}" class="btn btn-outline"><i class="fas fa-sync"></i> Actualiser</a>
        </div>
    </div>

    <div class="card" style="background: #fafbfc;">
        <div style="display: flex; flex-direction: column; gap: 12px; height: 600px; overflow-y: auto; padding-right: 12px;">
            
            {% for log in logs %}
            <div class="log-item" style="background: white; border-radius: 8px; box-shadow: var(--shadow-sm); border: 1px solid var(--border-color); padding: 16px 24px;">
                <div class="log-badge">
                    <span class="badge {% if log.action in ['CREATE', 'SIGNUP', 'SIGNUP_WEB'] %}badge-success{% elseif log.action == 'UPDATE' %}badge-warning{% elseif log.action == 'DELETE' %}badge-danger{% else %}badge-info{% endif %}" style="padding: 6px 16px; border-radius: 20px;">
                        {{ log.action }}
                    </span>
                </div>
                
                <div class="log-user">
                    <div style="font-weight: 700; color: var(--text-dark); margin-bottom: 4px;">Par: {{ log.user.email ?? 'System/Guest' }}</div>
                    <div style="font-size: 0.85rem; color: var(--text-muted);">ID Utilisateur concern├⌐: ******</div>
                </div>

                <div class="log-date" style="text-align: left;">
                    <div style="font-weight: 600; color: var(--primary-color);">{{ log.date|date('d/m/Y') }}</div>
                    <div style="font-size: 0.85rem;">{{ log.date|date('H:i:s') }}</div>
                </div>

                <div class="log-desc" style="text-align: left; padding-left: 24px; border-left: 1px solid var(--border-color);">
                    {% if log.action == 'CREATE' or log.action starts with 'SIGNUP' %}
                        User registered: {{ log.user.email ?? 'unknown' }}
                    {% elseif log.action == 'UPDATE' %}
                        User updated: {{ log.user.email ?? 'unknown' }}
                    {% elseif log.action == 'DELETE' %}
                        User deleted
                    {% else %}
                        User login: {{ log.user.email ?? 'unknown' }}
                    {% endif %}
                </div>
            </div>
            {% else %}
            <div style="text-align: center; padding: 40px; color: var(--text-muted);">
                Aucun log trouv├⌐.
            </div>
            {% endfor %}

        </div>
    </div>
{% endblock %}
