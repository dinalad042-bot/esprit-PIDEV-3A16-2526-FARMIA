{% extends 'layouts/agricole.html.twig' %}

{% block title %}Nouvelle Demande d'Analyse — FarmAI{% endblock %}

{% block body %}
<div style="padding:2rem; max-width:800px; margin:0 auto;">

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    <div style="margin-bottom:1.5rem;">
        <a href="{{ path('dashboard_agricole') }}" style="color:#666; text-decoration:none; font-size:0.9rem;">
            <i class="fa-solid fa-arrow-left"></i> Retour au tableau de bord
        </a>
        <h2 style="font-size:1.5rem; font-weight:700; color:#1a1a2e; margin:0.5rem 0 0;">
            <i class="fa-solid fa-file-medical" style="color:#2ecc71;"></i>
            Nouvelle Demande d'Analyse
        </h2>
        <p style="color:#888; margin:0.25rem 0 0; font-size:0.9rem;">
            Soumettez une demande d'analyse pour un animal ou une plante de votre ferme
        </p>
    </div>

    <form method="POST" enctype="multipart/form-data" style="background:#fff; border-radius:12px; padding:2rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
        
        {# Farm selection dropdown #}
        <div style="margin-bottom:1.5rem;">
            <label style="display:block; color:#333; font-weight:600; margin-bottom:0.5rem;">
                <i class="fa-solid fa-map-marker-alt" style="color:#2ecc71;"></i> Sélectionner une ferme *
            </label>
            <select name="ferme" required style="width:100%; padding:0.75rem; border:1px solid #ddd; border-radius:8px; font-size:0.95rem;">
                <option value="">-- Choisir une ferme --</option>
                {% for f in fermes %}
                    <option value="{{ f.idFerme }}" {{ ferme and ferme.idFerme == f.idFerme ? 'selected' : '' }}>
                        {{ f.nomFerme }}
                    </option>
                {% endfor %}
            </select>
            {% if fermes|length == 0 %}
                <p style="color:#888; font-size:0.85rem; margin-top:0.5rem;">
                    <i class="fa-solid fa-info-circle"></i> Vous n'avez pas encore de ferme enregistrée.
                </p>
            {% endif %}
        </div>

        {# Animal selection #}
        <div style="margin-bottom:1.5rem;">
            <label style="display:block; color:#333; font-weight:600; margin-bottom:0.5rem;">
                <i class="fa-solid fa-paw" style="color:#2ecc71;"></i> Sélectionner un animal (optionnel)
            </label>
            <select name="animal" style="width:100%; padding:0.75rem; border:1px solid #ddd; border-radius:8px; font-size:0.95rem;">
                <option value="">-- Choisir un animal --</option>
                {% for animal in animals %}
                    <option value="{{ animal.idAnimal }}">
                        {{ animal.espece }} - {{ animal.etatSante }} (Né: {{ animal.dateNaissance|date('d/m/Y') }})
                    </option>
                {% endfor %}
            </select>
            {% if animals|length == 0 %}
                <p style="color:#888; font-size:0.85rem; margin-top:0.5rem;">
                    <i class="fa-solid fa-info-circle"></i> Vous n'avez pas encore d'animaux enregistrés.
                </p>
            {% endif %}
        </div>

        {# OR separator #}
        <div style="text-align:center; margin:1.5rem 0; position:relative;">
            <div style="border-top:1px solid #ddd; position:absolute; top:50%; left:0; right:0;"></div>
            <span style="background:#fff; padding:0 1rem; color:#888; position:relative;">OU</span>
        </div>

        {# Plant selection #}
        <div style="margin-bottom:1.5rem;">
            <label style="display:block; color:#333; font-weight:600; margin-bottom:0.5rem;">
                <i class="fa-solid fa-seedling" style="color:#2ecc71;"></i> Sélectionner une plante (optionnel)
            </label>
            <select name="plante" style="width:100%; padding:0.75rem; border:1px solid #ddd; border-radius:8px; font-size:0.95rem;">
                <option value="">-- Choisir une plante --</option>
                {% for plante in plantes %}
                    <option value="{{ plante.idPlante }}">
                        {{ plante.nomEspece }} - {{ plante.cycleVie }} (Qté: {{ plante.quantite }})
                    </option>
                {% endfor %}
            </select>
            {% if plantes|length == 0 %}
                <p style="color:#888; font-size:0.85rem; margin-top:0.5rem;">
                    <i class="fa-solid fa-info-circle"></i> Vous n'avez pas encore de plantes enregistrées.
                </p>
            {% endif %}
        </div>

        {# Description #}
        <div style="margin-bottom:1.5rem;">
            <label style="display:block; color:#333; font-weight:600; margin-bottom:0.5rem;">
                <i class="fa-solid fa-comment" style="color:#2ecc71;"></i> Description de la demande *
            </label>
            <textarea name="description" required rows="5" 
                      style="width:100%; padding:0.75rem; border:1px solid #ddd; border-radius:8px; font-size:0.95rem; resize:vertical;"
                      placeholder="Décrivez le problème ou ce que vous souhaitez analyser..."></textarea>
            <p style="color:#888; font-size:0.8rem; margin-top:0.25rem;">
                Décrivez les symptômes, les observations ou vos préoccupations concernant l'animal ou la plante.
            </p>
        </div>

        {# Image upload #}
        <div style="margin-bottom:1.5rem;">
            <label style="display:block; color:#333; font-weight:600; margin-bottom:0.5rem;">
                <i class="fa-solid fa-image" style="color:#2ecc71;"></i> Photo (optionnel)
            </label>
            <input type="file" name="image" accept="image/*"
                   style="width:100%; padding:0.75rem; border:1px solid #ddd; border-radius:8px; font-size:0.95rem;">
            <p style="color:#888; font-size:0.8rem; margin-top:0.25rem;">
                Ajoutez une photo de l'animal, de la plante ou du problème observé.
            </p>
        </div>

        {# Submit buttons #}
        <div style="display:flex; gap:1rem; margin-top:2rem;">
            <button type="submit" 
                    style="flex:1; background:#2ecc71; color:#fff; border:none; padding:1rem; border-radius:8px; font-size:1rem; font-weight:600; cursor:pointer;">
                <i class="fa-solid fa-paper-plane"></i> Soumettre la demande
            </button>
            <a href="{{ path('dashboard_agricole') }}" 
               style="padding:1rem 2rem; background:#f0f0f0; color:#666; border-radius:8px; text-decoration:none; font-weight:600;">
                Annuler
            </a>
        </div>
    </form>
</div>
{% endblock %}
