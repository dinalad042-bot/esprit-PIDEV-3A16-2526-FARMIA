{% extends 'layouts/agricole.html.twig' %}

{% block title %}Mes Demandes d'Analyse — FarmAI{% endblock %}

{% block body %}
<div style="padding:2rem;">

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
        <div>
            <a href="{{ path('dashboard_agricole') }}" style="color:#666; text-decoration:none; font-size:0.9rem;">
                <i class="fa-solid fa-arrow-left"></i> Retour au tableau de bord
            </a>
            <h2 style="font-size:1.5rem; font-weight:700; color:#1a1a2e; margin:0.5rem 0 0;">
                <i class="fa-solid fa-clipboard-list" style="color:#2ecc71;"></i>
                Mes Demandes d'Analyse
            </h2>
            <p style="color:#888; margin:0.25rem 0 0; font-size:0.9rem;">
                Suivez l'état de vos demandes d'analyse
            </p>
        </div>
        <a href="{{ path('farmer_new_request') }}" class="btn btn-dark" style="background:#2ecc71; color:#fff; padding:0.75rem 1.5rem; border-radius:8px; text-decoration:none;">
            <i class="fa-solid fa-plus"></i> Nouvelle Demande
        </a>
    </div>

    {% if requests|length == 0 %}
        <div style="text-align:center; padding:4rem; background:#fff; border-radius:12px; color:#aaa;">
            <i class="fa-solid fa-clipboard" style="font-size:3rem; margin-bottom:1rem; display:block;"></i>
            <p style="font-size:1.1rem;">Vous n'avez pas encore fait de demandes d'analyse.</p>
            <a href="{{ path('farmer_new_request') }}" style="display:inline-block; margin-top:1rem; background:#2ecc71; color:#fff; padding:0.75rem 1.5rem; border-radius:8px; text-decoration:none;">
                Faire une demande
            </a>
        </div>
    {% else %}
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(350px,1fr)); gap:1.5rem;">
            {% for request in requests %}
            <div style="background:#fff; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.06); overflow:hidden;">
                
                {# Status Header #}
                <div style="padding:1rem; display:flex; justify-content:space-between; align-items:center;
                            {% if request.statut == 'en_attente' %}
                                background:linear-gradient(135deg,#ffebee,#ffcdd2);
                            {% elseif request.statut == 'en_cours' %}
                                background:linear-gradient(135deg,#e3f2fd,#bbdefb);
                            {% else %}
                                background:linear-gradient(135deg,#e8f8f0,#c8e6c9);
                            {% endif %}">
                    <span style="font-weight:700; font-size:0.9rem;
                                 {% if request.statut == 'en_attente' %}
                                     color:#c62828;
                                 {% elseif request.statut == 'en_cours' %}
                                     color:#1565c0;
                                 {% else %}
                                     color:#2e7d32;
                                 {% endif %}">
                        {% if request.statut == 'en_attente' %}
                            <i class="fa-solid fa-clock"></i> En attente
                        {% elseif request.statut == 'en_cours' %}
                            <i class="fa-solid fa-spinner fa-spin"></i> En cours
                        {% else %}
                            <i class="fa-solid fa-check-circle"></i> Terminée
                        {% endif %}
                    </span>
                    <span style="color:#666; font-size:0.8rem;">
                        #{{ request.id }}
                    </span>
                </div>

                <div style="padding:1.25rem;">
                    {# Date #}
                    <div style="color:#888; font-size:0.85rem; margin-bottom:0.75rem;">
                        <i class="fa-solid fa-calendar"></i> 
                        Soumise le {{ request.dateAnalyse ? request.dateAnalyse|date('d/m/Y à H:i') : 'N/A' }}
                    </div>

                    {# Target info #}
                    {% if request.animalCible %}
                    <div style="margin-bottom:0.5rem;">
                        <span style="background:#e8f8f0; color:#27ae60; padding:2px 8px; border-radius:4px; font-size:0.8rem;">
                            <i class="fa-solid fa-paw"></i> {{ request.animalCible.espece }}
                        </span>
                    </div>
                    {% endif %}

                    {% if request.planteCible %}
                    <div style="margin-bottom:0.5rem;">
                        <span style="background:#e8f8f0; color:#27ae60; padding:2px 8px; border-radius:4px; font-size:0.8rem;">
                            <i class="fa-solid fa-seedling"></i> {{ request.planteCible.nomEspece }}
                        </span>
                    </div>
                    {% endif %}

                    {# Description #}
                    <p style="color:#555; font-size:0.9rem; line-height:1.5; margin:0.75rem 0;">
                        {{ request.descriptionDemande ? request.descriptionDemande|slice(0, 100) : 'Aucune description' }}
                        {% if request.descriptionDemande and request.descriptionDemande|length > 100 %}...{% endif %}
                    </p>

                    {# Image preview #}
                    {% if request.imageUrl %}
                    <div style="margin:1rem 0;">
                        <img src="{{ request.imageUrl }}" alt="Image de la demande"
                             style="width:100%; height:120px; object-fit:cover; border-radius:6px;"
                             onerror="this.style.display='none';">
                    </div>
                    {% endif %}

                    {# Expert info if assigned #}
                    {% if request.technicien %}
                    <div style="background:#f8f9fa; padding:0.75rem; border-radius:6px; margin-top:1rem;">
                        <div style="color:#888; font-size:0.8rem; margin-bottom:0.25rem;">Expert assigné</div>
                        <div style="color:#333; font-weight:500;">
                            {{ request.technicien.prenom }} {{ request.technicien.nom }}
                        </div>
                    </div>
                    {% endif %}

                    {# Result if available #}
                    {% if request.resultatTechnique %}
                    <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid #eee;">
                        <div style="color:#2ecc71; font-weight:600; margin-bottom:0.5rem;">
                            <i class="fa-solid fa-clipboard-check"></i> Résultat de l'analyse
                        </div>
                        <p style="color:#555; font-size:0.85rem; line-height:1.5; margin:0;">
                            {{ request.resultatTechnique|slice(0, 150) }}
                            {% if request.resultatTechnique|length > 150 %}...{% endif %}
                        </p>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
