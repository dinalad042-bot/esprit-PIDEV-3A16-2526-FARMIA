{% extends 'layouts/fournisseur.html.twig' %}

{% block title %}Espace Fournisseur - FarmAI{% endblock %}

{% block body %}
<div class="welcome-section">
    <h1 class="welcome-title">Bienvenue, {{ app.user.prenom|default('Fournisseur') }} {{ app.user.nom|default('') }} !</h1>
    <p class="welcome-subtitle">Gérez vos produits et commandes facilement <i class="fa-solid fa-box-open" style="color: var(--primary-green);"></i></p>
</div>

{# ─── Stats Cards ─────────────────────────────────────────────────────────── #}
<div class="stats-grid">
    <div class="stat-card green">
        <div class="stat-value">24</div>
        <div class="stat-label">Produits</div>
        <div class="stat-sublabel">Au catalogue</div>
        <div class="stat-footer stat-footer-line">
            <i class="fa-solid fa-arrow-trend-up" style="color: #4ade80;"></i> +5 ce mois
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-value" style="color: var(--dark-bg);">8</div>
        <div class="stat-label" style="color: var(--dark-bg);">Commandes</div>
        <div class="stat-sublabel">En cours</div>
        <div class="stat-footer stat-footer-line" style="color: #cbd5e1;">À traiter</div>
    </div>

    <div class="stat-card light-gray">
        <div class="stat-value" style="color: var(--dark-bg);">52</div>
        <div class="stat-label" style="color: var(--dark-bg);">Ventes</div>
        <div class="stat-sublabel">Ce mois</div>
        <div class="stat-footer stat-footer-line" style="color: #cbd5e1;">
            <i class="fa-solid fa-chart-line" style="color: #22c55e;"></i> +12%
        </div>
    </div>

    <div class="stat-card dark">
        <div class="stat-value">3</div>
        <div class="stat-label">Ruptures</div>
        <div class="stat-sublabel">Stock faible</div>
        <div class="stat-footer stat-footer-line">
            <i class="fa-solid fa-triangle-exclamation" style="color: #f59e0b;"></i> Réapprovisionner
        </div>
    </div>
</div>

{# ─── Bottom Section ──────────────────────────────────────────────────────── #}
<div class="bottom-grid">
    <div class="action-card">
        <div class="action-header">
            <h3 class="action-title"><i class="fa-solid fa-bolt"></i> Actions Rapides</h3>
            <i class="fa-solid fa-ellipsis" style="color: #cbd5e1; cursor: pointer;"></i>
        </div>

        <div class="btn-group">
            <a href="{{ path('erp_dashboard') }}" class="btn btn-dark"><i class="fa-solid fa-store"></i> FarmIA Desk ERP</a>
            <a href="{{ path('erp_vente_new') }}" class="btn btn-outline-green"><i class="fa-solid fa-receipt"></i> Nouvelle Vente</a>
            <a href="{{ path('erp_vente_index') }}" class="btn btn-outline-green"><i class="fa-solid fa-list"></i> Mes Ventes</a>
        </div>

        <div class="action-list">
            <div class="list-item">
                <div class="list-icon new">NEW</div>
                <div class="list-text">Nouvelle commande reçue</div>
            </div>
            <div class="list-item">
                <div class="list-icon refresh"><i class="fa-solid fa-arrows-rotate"></i></div>
                <div class="list-text">Stock mis à jour automatiquement</div>
            </div>
        </div>
    </div>

    <div class="enterprise-card">
        <h3 class="enterprise-title"><i class="fa-solid fa-store"></i> FarmIA Desk ERP</h3>
        <p class="enterprise-text">
            Gérez votre catalogue de services, enregistrez vos achats et ventes, suivez votre stock et recevez des alertes automatiques.
        </p>
        <a href="{{ path('erp_dashboard') }}" style="display:inline-block;margin-top:.75rem;background:#22c55e;color:#fff;padding:.4rem .9rem;border-radius:8px;font-size:.85rem;font-weight:600;text-decoration:none;">
            <i class="fa-solid fa-arrow-right"></i> Accéder à l'ERP
        </a>
        <i class="fa-solid fa-truck-field enterprise-icon"></i>
    </div>
</div>
{% endblock %}
