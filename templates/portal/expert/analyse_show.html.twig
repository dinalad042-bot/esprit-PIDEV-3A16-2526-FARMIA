{% extends 'layouts/expert.html.twig' %}

{% block title %}Analyse #{{ analyse.id }} — FarmAI{% endblock %}

{% block body %}
<div style="padding:2rem;">

    {# Header with Actions #}
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
        <div>
            <a href="{{ path('expert_analyses_list') }}" style="color:#666; text-decoration:none; font-size:0.9rem;">
                <i class="fa-solid fa-arrow-left"></i> Retour aux analyses
            </a>
            <h2 style="font-size:1.5rem; font-weight:700; color:#1a1a2e; margin:0.5rem 0 0;">
                <i class="fa-solid fa-flask" style="color:#2ecc71;"></i>
                Analyse #{{ analyse.id }}
            </h2>
        </div>
        <div style="display:flex; gap:0.5rem; align-items:center;">
            {# Status Badge #}
            <span style="background:{% if analyse.statut == 'en_attente' %}#fff3e0{% elseif analyse.statut == 'en_cours' %}#e3f2fd{% elseif analyse.statut == 'terminee' %}#e8f8f0{% else %}#f5f5f5{% endif %}; 
                         color:{% if analyse.statut == 'en_attente' %}#f39c12{% elseif analyse.statut == 'en_cours' %}#3498db{% elseif analyse.statut == 'terminee' %}#27ae60{% else %}#7f8c8d{% endif %}; 
                         padding:4px 12px; border-radius:12px; font-size:0.85rem; font-weight:600;">
                {{ analyse.statut|replace({'_': ' '})|title }}
            </span>
            <span style="background:#e8f8f0; color:#27ae60; padding:4px 12px; border-radius:12px; font-size:0.85rem;">
                {{ analyse.nbConseils }} conseil(s)
            </span>
        </div>
    </div>

    {# Action Buttons Bar #}
    <div style="margin-bottom:1.5rem; display:flex; gap:0.5rem; flex-wrap:wrap;">
        <a href="{{ path('expert_analyse_edit', {id: analyse.id}) }}" class="btn btn-outline" style="background:#fff; border:1px solid #ddd; color:#333; padding:8px 16px; border-radius:8px; text-decoration:none;">
            <i class="fa-solid fa-pen"></i> Modifier
        </a>
        <form method="POST" action="{{ path('expert_analyse_delete', {id: analyse.id}) }}" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette analyse ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ analyse.id) }}">
            <button type="submit" style="background:#fff; border:1px solid #e74c3c; color:#e74c3c; padding:8px 16px; border-radius:8px; cursor:pointer;">
                <i class="fa-solid fa-trash"></i> Supprimer
            </button>
        </form>
        
        {# Status Workflow Buttons #}
        {% if analyse.statut != 'en_cours' %}
        <form method="POST" action="{{ path('expert_analyse_status', {id: analyse.id, status: 'en_cours'}) }}" style="display:inline;">
            <button type="submit" style="background:#3498db; color:#fff; border:none; padding:8px 16px; border-radius:8px; cursor:pointer;">
                <i class="fa-solid fa-play"></i> Démarrer
            </button>
        </form>
        {% endif %}
        {% if analyse.statut != 'terminee' %}
        <form method="POST" action="{{ path('expert_analyse_status', {id: analyse.id, status: 'terminee'}) }}" style="display:inline;">
            <button type="submit" style="background:#27ae60; color:#fff; border:none; padding:8px 16px; border-radius:8px; cursor:pointer;">
                <i class="fa-solid fa-check"></i> Terminer
            </button>
        </form>
        {% endif %}
        {% if analyse.statut != 'annulee' %}
        <form method="POST" action="{{ path('expert_analyse_status', {id: analyse.id, status: 'annulee'}) }}" style="display:inline;">
            <button type="submit" style="background:#7f8c8d; color:#fff; border:none; padding:8px 16px; border-radius:8px; cursor:pointer;">
                <i class="fa-solid fa-ban"></i> Annuler
            </button>
        </form>
        {% endif %}
        
        {# AI Diagnosis Button #}
        {% if analyse.imageUrl %}
            {% if analyse.hasAiDiagnosis %}
            <a href="{{ path('expert_analyse_ai_result', {id: analyse.id}) }}" style="background:#9b59b6; color:#fff; text-decoration:none; border:none; padding:8px 16px; border-radius:8px; display:inline-flex; align-items:center; gap:4px;">
                <i class="fa-solid fa-robot"></i> Voir IA
            </a>
            {% else %}
            <form method="POST" action="{{ path('expert_analyse_diagnose', {id: analyse.id}) }}" style="display:inline;">
                <button type="submit" style="background:#9b59b6; color:#fff; border:none; padding:8px 16px; border-radius:8px; cursor:pointer;" onclick="return confirm('Lancer le diagnostic IA sur cette image ?');">
                    <i class="fa-solid fa-robot"></i> Diagnostiquer IA
                </button>
            </form>
            {% endif %}
        {% endif %}

        {# PDF Export Button #}
        <a href="{{ path('expert_analyse_export_pdf', {id: analyse.id}) }}" style="background:#e74c3c; color:#fff; text-decoration:none; border:none; padding:8px 16px; border-radius:8px; display:inline-flex; align-items:center; gap:4px;">
            <i class="fa-solid fa-file-pdf"></i> Exporter PDF
        </a>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
        {# Left Column - Details #}
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <h3 style="margin:0 0 1rem; color:#1a1a2e; font-size:1.1rem;">
                <i class="fa-solid fa-info-circle" style="color:#2ecc71;"></i> Informations
            </h3>

            <div style="margin-bottom:1rem;">
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.25rem;">Date d'analyse</div>
                <div style="font-weight:600; color:#333;">
                    {{ analyse.dateAnalyse ? analyse.dateAnalyse|date('d/m/Y à H:i') : 'Non définie' }}
                </div>
            </div>

            {% if analyse.ferme %}
            <div style="margin-bottom:1rem;">
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.25rem;">Ferme</div>
                <div style="font-weight:600; color:#333;">
                    <i class="fa-solid fa-map-marker-alt" style="color:#2ecc71;"></i>
                    {{ analyse.ferme.nomFerme }}
                </div>
                {% if analyse.ferme.lieu %}
                <div style="color:#666; font-size:0.85rem; margin-top:0.25rem;">
                    {{ analyse.ferme.lieu }}
                </div>
                {% endif %}
            </div>
            {% endif %}

            <div style="margin-bottom:1rem;">
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.25rem;">Technicien</div>
                <div style="font-weight:600; color:#333;">
                    {{ analyse.technicien.prenom }} {{ analyse.technicien.nom }}
                </div>
                <div style="color:#666; font-size:0.85rem; margin-top:0.25rem;">
                    {{ analyse.technicien.email }}
                </div>
            </div>

            {% if analyse.resultatTechnique %}
            <div>
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.25rem;">Résultat technique</div>
                <div style="background:#f8f9fa; padding:1rem; border-radius:8px; color:#444; line-height:1.6;">
                    {{ analyse.resultatTechnique|nl2br }}
                </div>
            </div>
            {% endif %}
        </div>

        {# Right Column - Image #}
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <h3 style="margin:0 0 1rem; color:#1a1a2e; font-size:1.1rem;">
                <i class="fa-solid fa-image" style="color:#2ecc71;"></i> Image d'analyse
            </h3>

            {% if analyse.imageUrl %}
                <img src="{{ analyse.imageUrl }}" alt="Analyse"
                     style="width:100%; max-height:300px; object-fit:cover; border-radius:8px;"
                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div style="display:none; height:200px; background:linear-gradient(135deg,#2ecc71,#27ae60); border-radius:8px; align-items:center; justify-content:center;">
                    <i class="fa-solid fa-flask" style="color:rgba(255,255,255,0.6); font-size:3rem;"></i>
                </div>
            {% else %}
                <div style="height:200px; background:linear-gradient(135deg,#2ecc71,#27ae60); border-radius:8px; display:flex; align-items:center; justify-content:center;">
                    <i class="fa-solid fa-flask" style="color:rgba(255,255,255,0.6); font-size:3rem;"></i>
                </div>
                <p style="text-align:center; color:#888; margin-top:1rem;">Aucune image associée</p>
            {% endif %}
        </div>
    </div>

    {# Weather Panel #}
    {% set weatherData = analyse.getWeatherData() %}
    {% if weatherData is not null and weatherData.success %}
    <div style="margin-top:1.5rem; background:linear-gradient(135deg,#2193b0 0%,#6dd5ed 100%); border-radius:12px; padding:1.5rem; color:#fff;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <h3 style="margin:0; font-size:1.1rem;">
                <i class="fa-solid fa-cloud-sun" style="margin-right:8px;"></i> Conditions Météo
            </h3>
            <span style="background:rgba(255,255,255,0.2); padding:4px 12px; border-radius:12px; font-size:0.85rem;">
                {{ analyse.weatherFetchedAt|date('d/m/Y H:i') }}
            </span>
        </div>
        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:1rem;">
            <div style="background:rgba(255,255,255,0.1); border-radius:8px; padding:1rem; text-align:center;">
                <div style="font-size:2rem; font-weight:700;">{{ analyse.weatherData.temperature }}°C</div>
                <div style="opacity:0.8; font-size:0.85rem;">Température</div>
            </div>
            <div style="background:rgba(255,255,255,0.1); border-radius:8px; padding:1rem; text-align:center;">
                <div style="font-size:2rem; font-weight:700;">{{ analyse.weatherData.humidity }}%</div>
                <div style="opacity:0.8; font-size:0.85rem;">Humidité</div>
            </div>
            <div style="background:rgba(255,255,255,0.1); border-radius:8px; padding:1rem; text-align:center;">
                <div style="font-size:1.2rem; font-weight:600;">{{ analyse.weatherData.description }}</div>
                <div style="opacity:0.8; font-size:0.85rem;">{{ analyse.weatherData.location }}</div>
            </div>
        </div>
        {% set weatherAdvice = weatherService.getAgriAdvice(analyse.weatherData) %}
        {% if weatherAdvice is not empty %}
        <div style="margin-top:1rem; background:rgba(255,255,255,0.15); border-radius:8px; padding:1rem;">
            {{ weatherAdvice|nl2br }}
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# AI Diagnosis Section #}
    {% if analyse.hasAiDiagnosis %}
    {% set aiResult = analyse.aiDiagnosisResult is not null ? analyse.aiDiagnosisResult|raw|json_decode : {} %}
    <div style="margin-top:1.5rem; background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); border-radius:12px; padding:1.5rem; color:#fff;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <h3 style="margin:0; font-size:1.1rem;">
                <i class="fa-solid fa-robot" style="margin-right:8px;"></i> Diagnostic IA
            </h3>
            <div style="display:flex; gap:0.5rem; align-items:center;">
                <span style="background:rgba(255,255,255,0.2); padding:4px 12px; border-radius:12px; font-size:0.85rem;">
                    Confiance: {{ analyse.aiConfidenceScore }}
                </span>
                <span style="background:rgba(255,255,255,0.2); padding:4px 12px; border-radius:12px; font-size:0.85rem;">
                    {{ analyse.aiDiagnosisDate|date('d/m/Y H:i') }}
                </span>
            </div>
        </div>
        
        <div style="background:rgba(255,255,255,0.1); border-radius:8px; padding:1rem; margin-bottom:1rem;">
            <div style="font-size:0.85rem; opacity:0.8; margin-bottom:0.25rem;">Condition détectée</div>
            <div style="font-size:1.1rem; font-weight:600;">{{ aiResult.condition|default('Non déterminé') }}</div>
        </div>
        
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div style="background:rgba(255,255,255,0.1); border-radius:8px; padding:1rem;">
                <div style="font-size:0.8rem; opacity:0.8; margin-bottom:0.25rem;"><i class="fa-solid fa-heart-pulse"></i> Symptômes</div>
                <div style="font-size:0.9rem;">
                    {% if aiResult.symptoms is iterable %}
                        {{ aiResult.symptoms|join(', ')|slice(0,100) }}{% if aiResult.symptoms|join(', ')|length > 100 %}...{% endif %}
                    {% else %}
                        {{ aiResult.symptoms|default('-')|slice(0,100) }}{% if aiResult.symptoms|default('-')|length > 100 %}...{% endif %}
                    {% endif %}
                </div>
            </div>
            <div style="background:rgba(255,255,255,0.1); border-radius:8px; padding:1rem;">
                <div style="font-size:0.8rem; opacity:0.8; margin-bottom:0.25rem;"><i class="fa-solid fa-pills"></i> Traitement</div>
                <div style="font-size:0.9rem;">
                    {% if aiResult.treatment is iterable %}
                        {{ aiResult.treatment|join(', ')|slice(0,100) }}{% if aiResult.treatment|join(', ')|length > 100 %}...{% endif %}
                    {% else %}
                        {{ aiResult.treatment|default('-')|slice(0,100) }}{% if aiResult.treatment|default('-')|length > 100 %}...{% endif %}
                    {% endif %}
                </div>
            </div>
        </div>
        
        <div style="margin-top:1rem; display:flex; gap:0.5rem;">
            <a href="{{ path('expert_analyse_ai_result', {id: analyse.id}) }}" style="background:#fff; color:#764ba2; text-decoration:none; padding:8px 16px; border-radius:8px; font-weight:500;">
                Voir détails complet <i class="fa-solid fa-arrow-right"></i>
            </a>
            <form method="POST" action="{{ path('expert_analyse_diagnose', {id: analyse.id}) }}" style="display:inline;">
                <button type="submit" style="background:rgba(255,255,255,0.2); color:#fff; border:none; padding:8px 16px; border-radius:8px; cursor:pointer;">
                    <i class="fa-solid fa-rotate"></i> Relancer
                </button>
            </form>
        </div>
    </div>
    {% endif %}

    {# Conseils Section #}
    <div style="margin-top:1.5rem; background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <h3 style="margin:0; color:#1a1a2e; font-size:1.1rem;">
                <i class="fa-solid fa-lightbulb" style="color:#f39c12;"></i> Conseils associés
            </h3>
            <a href="{{ path('expert_analyse_conseil_new', {id: analyse.id}) }}" class="btn btn-dark" style="font-size:0.85rem;">
                <i class="fa-solid fa-plus"></i> Ajouter un conseil
            </a>
        </div>

        {% if analyse.conseils|length > 0 %}
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(300px,1fr)); gap:1rem;">
            {% for conseil in analyse.conseils %}
            <div style="background:#f8f9fa; border-radius:8px; padding:1rem; border-left:4px solid {% if conseil.priorite.value == 'HAUTE' %}#e74c3c{% elseif conseil.priorite.value == 'MOYENNE' %}#f39c12{% else %}#2ecc71{% endif %};">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
                    <span style="font-weight:600; color:#333;">Conseil #{{ conseil.id }}</span>
                    <span style="background:{% if conseil.priorite.value == 'HAUTE' %}#ffebee{% elseif conseil.priorite.value == 'MOYENNE' %}#fff3e0{% else %}#e8f8f0{% endif %}; 
                                 color:{% if conseil.priorite.value == 'HAUTE' %}#e74c3c{% elseif conseil.priorite.value == 'MOYENNE' %}#f39c12{% else %}#27ae60{% endif %}; 
                                 padding:2px 8px; border-radius:8px; font-size:0.75rem;">
                        {{ conseil.priorite.label }}
                    </span>
                </div>
                <p style="color:#555; font-size:0.85rem; line-height:1.5; margin:0;">
                    {{ conseil.descriptionConseil|slice(0, 100) }}{% if conseil.descriptionConseil|length > 100 %}...{% endif %}
                </p>
                <div style="display:flex; gap:0.5rem; margin-top:0.75rem;">
                    <a href="{{ path('expert_conseil_show', {id: conseil.id}) }}" style="color:#2ecc71; font-size:0.85rem; text-decoration:none;">
                        Voir <i class="fa-solid fa-arrow-right"></i>
                    </a>
                    <a href="{{ path('expert_conseil_edit', {id: conseil.id}) }}" style="color:#3498db; font-size:0.85rem; text-decoration:none;">
                        <i class="fa-solid fa-pen"></i> Modifier
                    </a>
                    <form method="POST" action="{{ path('expert_conseil_delete', {id: conseil.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer ce conseil ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ conseil.id) }}">
                        <button type="submit" style="background:none; border:none; color:#e74c3c; font-size:0.85rem; cursor:pointer; padding:0;">
                            <i class="fa-solid fa-trash"></i> Supprimer
                        </button>
                    </form>
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <div style="text-align:center; padding:2rem; color:#888;">
            <i class="fa-solid fa-lightbulb" style="font-size:2rem; margin-bottom:0.5rem; display:block;"></i>
            <p>Aucun conseil associé. <a href="{{ path('expert_analyse_conseil_new', {id: analyse.id}) }}" style="color:#2ecc71;">Ajouter un conseil</a></p>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
