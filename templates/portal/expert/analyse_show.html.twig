{% extends 'layouts/expert.html.twig' %}

{% block title %}Analyse #{{ analyse.id }} — FarmAI{% endblock %}

{% block body %}
<div style="padding:2rem;">

    {# Header #}
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
        <div>
            <a href="{{ path('expert_analyses_list') }}" style="color:#666; text-decoration:none; font-size:0.9rem;">
                <i class="fa-solid fa-arrow-left"></i> Retour aux analyses
            </a>
            <h2 style="font-size:1.5rem; font-weight:700; color:#1a1a2e; margin:0.5rem 0 0;">
                <i class="fa-solid fa-flask" style="color:#2ecc71;"></i>
                Analyse #{{ analyse.id }}
            </h2>
        </div>
        <span style="background:#e8f8f0; color:#27ae60; padding:4px 12px; border-radius:12px; font-size:0.85rem;">
            {{ analyse.nbConseils }} conseil(s) associé(s)
        </span>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
        {# Left Column - Details #}
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <h3 style="margin:0 0 1rem; color:#1a1a2e; font-size:1.1rem;">
                <i class="fa-solid fa-info-circle" style="color:#2ecc71;"></i> Informations
            </h3>

            <div style="margin-bottom:1rem;">
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.25rem;">Date d'analyse</div>
                <div style="font-weight:600; color:#333;">
                    {{ analyse.dateAnalyse ? analyse.dateAnalyse|date('d/m/Y à H:i') : 'Non définie' }}
                </div>
            </div>

            {% if analyse.ferme %}
            <div style="margin-bottom:1rem;">
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.25rem;">Ferme</div>
                <div style="font-weight:600; color:#333;">
                    <i class="fa-solid fa-map-marker-alt" style="color:#2ecc71;"></i>
                    {{ analyse.ferme.nomFerme }}
                </div>
                {% if analyse.ferme.localisation %}
                <div style="color:#666; font-size:0.85rem; margin-top:0.25rem;">
                    {{ analyse.ferme.localisation }}
                </div>
                {% endif %}
            </div>
            {% endif %}

            <div style="margin-bottom:1rem;">
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.25rem;">Technicien</div>
                <div style="font-weight:600; color:#333;">
                    {{ analyse.technicien.prenom }} {{ analyse.technicien.nom }}
                </div>
                <div style="color:#666; font-size:0.85rem; margin-top:0.25rem;">
                    {{ analyse.technicien.email }}
                </div>
            </div>

            {% if analyse.resultatTechnique %}
            <div>
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.25rem;">Résultat technique</div>
                <div style="background:#f8f9fa; padding:1rem; border-radius:8px; color:#444; line-height:1.6;">
                    {{ analyse.resultatTechnique|nl2br }}
                </div>
            </div>
            {% endif %}
        </div>

        {# Right Column - Image #}
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <h3 style="margin:0 0 1rem; color:#1a1a2e; font-size:1.1rem;">
                <i class="fa-solid fa-image" style="color:#2ecc71;"></i> Image d'analyse
            </h3>

            {% if analyse.imageUrl %}
                <img src="{{ analyse.imageUrl }}" alt="Analyse"
                     style="width:100%; max-height:300px; object-fit:cover; border-radius:8px;"
                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div style="display:none; height:200px; background:linear-gradient(135deg,#2ecc71,#27ae60); border-radius:8px; align-items:center; justify-content:center;">
                    <i class="fa-solid fa-flask" style="color:rgba(255,255,255,0.6); font-size:3rem;"></i>
                </div>
            {% else %}
                <div style="height:200px; background:linear-gradient(135deg,#2ecc71,#27ae60); border-radius:8px; display:flex; align-items:center; justify-content:center;">
                    <i class="fa-solid fa-flask" style="color:rgba(255,255,255,0.6); font-size:3rem;"></i>
                </div>
                <p style="text-align:center; color:#888; margin-top:1rem;">Aucune image associée</p>
            {% endif %}
        </div>
    </div>

    {# Conseils Section #}
    {% if analyse.conseils|length > 0 %}
    <div style="margin-top:1.5rem; background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
        <h3 style="margin:0 0 1rem; color:#1a1a2e; font-size:1.1rem;">
            <i class="fa-solid fa-lightbulb" style="color:#f39c12;"></i> Conseils associés
        </h3>

        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(300px,1fr)); gap:1rem;">
            {% for conseil in analyse.conseils %}
            <div style="background:#f8f9fa; border-radius:8px; padding:1rem; border-left:4px solid {% if conseil.priorite.value == 'HAUTE' %}#e74c3c{% elseif conseil.priorite.value == 'MOYENNE' %}#f39c12{% else %}#2ecc71{% endif %};">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
                    <span style="font-weight:600; color:#333;">Conseil #{{ conseil.id }}</span>
                    <span style="background:{% if conseil.priorite.value == 'HAUTE' %}#ffebee{% elseif conseil.priorite.value == 'MOYENNE' %}#fff3e0{% else %}#e8f8f0{% endif %}; 
                                 color:{% if conseil.priorite.value == 'HAUTE' %}#e74c3c{% elseif conseil.priorite.value == 'MOYENNE' %}#f39c12{% else %}#27ae60{% endif %}; 
                                 padding:2px 8px; border-radius:8px; font-size:0.75rem;">
                        {{ conseil.priorite.label }}
                    </span>
                </div>
                <p style="color:#555; font-size:0.85rem; line-height:1.5; margin:0;">
                    {{ conseil.descriptionConseil|slice(0, 100) }}{% if conseil.descriptionConseil|length > 100 %}...{% endif %}
                </p>
                <a href="{{ path('expert_conseil_show', {id: conseil.id}) }}" style="display:inline-block; margin-top:0.75rem; color:#2ecc71; font-size:0.85rem; text-decoration:none;">
                    Voir le conseil <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# Actions #}
    <div style="margin-top:1.5rem; display:flex; gap:1rem;">
        <a href="{{ path('app_conseil_new') }}" class="btn btn-dark">
            <i class="fa-solid fa-plus"></i> Ajouter un conseil
        </a>
    </div>
</div>
{% endblock %}
