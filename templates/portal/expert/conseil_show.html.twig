{% extends 'layouts/expert.html.twig' %}

{% block title %}Conseil #{{ conseil.id }} — FarmAI{% endblock %}

{% block body %}
<div style="padding:2rem;">

    {# Header #}
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
        <div>
            <a href="{{ path('expert_conseils_list') }}" style="color:#666; text-decoration:none; font-size:0.9rem;">
                <i class="fa-solid fa-arrow-left"></i> Retour aux recommandations
            </a>
            <h2 style="font-size:1.5rem; font-weight:700; color:#1a1a2e; margin:0.5rem 0 0;">
                <i class="fa-solid fa-lightbulb" style="color:#f39c12;"></i>
                Conseil #{{ conseil.id }}
            </h2>
        </div>
        <span style="background:{% if conseil.priorite.value == 'HAUTE' %}#ffebee{% elseif conseil.priorite.value == 'MOYENNE' %}#fff3e0{% else %}#e8f8f0{% endif %}; 
                     color:{% if conseil.priorite.value == 'HAUTE' %}#e74c3c{% elseif conseil.priorite.value == 'MOYENNE' %}#f39c12{% else %}#27ae60{% endif %}; 
                     padding:4px 12px; border-radius:12px; font-size:0.85rem; font-weight:600;">
            {{ conseil.priorite.label }}
        </span>
    </div>

    <div style="display:grid; grid-template-columns:2fr 1fr; gap:1.5rem;">
        {# Left Column - Conseil Details #}
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <h3 style="margin:0 0 1rem; color:#1a1a2e; font-size:1.1rem;">
                <i class="fa-solid fa-file-alt" style="color:#f39c12;"></i> Description du conseil
            </h3>

            <div style="background:#f8f9fa; padding:1.5rem; border-radius:8px; color:#444; line-height:1.8; font-size:1rem;">
                {{ conseil.descriptionConseil|nl2br }}
            </div>

            {% if conseil.analyse and conseil.analyse.resultatTechnique %}
            <div style="margin-top:1.5rem;">
                <h4 style="margin:0 0 0.75rem; color:#1a1a2e; font-size:1rem;">
                    <i class="fa-solid fa-flask" style="color:#2ecc71;"></i> Résultat technique de l'analyse
                </h4>
                <div style="background:#e8f8f0; padding:1rem; border-radius:8px; color:#444; line-height:1.6; font-size:0.9rem;">
                    {{ conseil.analyse.resultatTechnique|nl2br }}
                </div>
            </div>
            {% endif %}
        </div>

        {# Right Column - Analysis Info #}
        {% if conseil.analyse %}
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <h3 style="margin:0 0 1rem; color:#1a1a2e; font-size:1.1rem;">
                <i class="fa-solid fa-link" style="color:#2ecc71;"></i> Analyse associée
            </h3>

            <div style="margin-bottom:1rem;">
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.25rem;">ID Analyse</div>
                <div style="font-weight:600; color:#333;">
                    #{{ conseil.analyse.id }}
                </div>
            </div>

            <div style="margin-bottom:1rem;">
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.25rem;">Date</div>
                <div style="font-weight:600; color:#333;">
                    {{ conseil.analyse.dateAnalyse ? conseil.analyse.dateAnalyse|date('d/m/Y') : 'Non définie' }}
                </div>
            </div>

            {% if conseil.analyse.ferme %}
            <div style="margin-bottom:1rem;">
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.25rem;">Ferme</div>
                <div style="font-weight:600; color:#333;">
                    <i class="fa-solid fa-map-marker-alt" style="color:#2ecc71;"></i>
                    {{ conseil.analyse.ferme.nomFerme }}
                </div>
            </div>
            {% endif %}

            {% if conseil.analyse.imageUrl %}
            <div style="margin-bottom:1rem;">
                <div style="color:#888; font-size:0.85rem; margin-bottom:0.5rem;">Image d'analyse</div>
                <img src="{{ conseil.analyse.imageUrl }}" alt="Analyse"
                     style="width:100%; height:150px; object-fit:cover; border-radius:8px;"
                     onerror="this.style.display='none';">
            </div>
            {% endif %}

            <a href="{{ path('expert_analyse_show', {id: conseil.analyse.id}) }}"
               style="display:block; text-align:center; background:#2ecc71; color:#fff; padding:10px; border-radius:8px; text-decoration:none; font-size:0.9rem; margin-top:1rem;">
                <i class="fa-solid fa-eye"></i> Voir l'analyse complète
            </a>
        </div>
        {% endif %}
    </div>

    {# Actions #}
    <div style="margin-top:1.5rem; display:flex; gap:1rem;">
        <a href="{{ path('expert_conseils_list') }}" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left"></i> Retour à la liste
        </a>
    </div>
</div>
{% endblock %}
