{% extends 'layouts/expert.html.twig' %}
{% block title %}Modifier Conseil #{{ conseil.id }} — FarmAI{% endblock %}

{% block body %}
<div style="padding:2rem; max-width:650px;">

    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem;">
        <a href="{{ path('expert_conseil_show', {id: conseil.id}) }}" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h2 style="font-size:1.4rem; font-weight:700; color:#1a1a2e; margin:0;">
            <i class="fa-solid fa-lightbulb" style="color:#f39c12;"></i>
            Modifier Conseil #{{ conseil.id }}
        </h2>
    </div>

    <div style="background:#fff; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.06); padding:2rem;">
        <div style="margin-bottom:1.5rem; padding:1rem; background:#f8f9fa; border-radius:8px;">
            <div style="color:#666; font-size:0.85rem; margin-bottom:0.25rem;">Analyse associée</div>
            <div style="font-weight:600; color:#333;">
                <i class="fa-solid fa-flask" style="color:#2ecc71; margin-right:4px;"></i>
                Analyse #{{ conseil.analyse.id }}
                {% if conseil.analyse.ferme %}
                    - {{ conseil.analyse.ferme.nomFerme }}
                {% endif %}
            </div>
        </div>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'modern-form'}}) }}

        <div class="form-group" style="margin-bottom:1.5rem;">
            {{ form_label(form.prioriteRaw) }}
            {{ form_errors(form.prioriteRaw) }}
            {{ form_widget(form.prioriteRaw) }}
        </div>
        <div class="form-group" style="margin-bottom:1.5rem;">
            {{ form_label(form.descriptionConseil) }}
            {{ form_errors(form.descriptionConseil) }}
            {{ form_widget(form.descriptionConseil) }}
            <small style="color:#888;">Minimum 10 caractères</small>
        </div>

        <div style="display:flex; gap:1rem; margin-top:1.5rem;">
            <button type="submit" class="btn btn-dark">
                <i class="fa-solid fa-floppy-disk"></i> Enregistrer
            </button>
            <a href="{{ path('expert_conseil_show', {id: conseil.id}) }}" class="btn btn-secondary">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}