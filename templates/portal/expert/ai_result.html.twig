{% extends 'layouts/expert.html.twig' %}

{% block title %}Diagnostic IA - Analyse #{{ analyse.id }} — FarmAI{% endblock %}

{% block body %}
<div style="padding:2rem; max-width:900px;">

    {# Header #}
    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem;">
        <a href="{{ path('expert_analyse_show', {id: analyse.id}) }}" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div>
            <h2 style="font-size:1.4rem; font-weight:700; color:#1a1a2e; margin:0;">
                <i class="fa-solid fa-robot" style="color:#9b59b6;"></i>
                Diagnostic IA Complet
            </h2>
            <p style="color:#666; margin:0.25rem 0 0; font-size:0.9rem;">Analyse #{{ analyse.id }} - {{ analyse.ferme.nomFerme }}</p>
        </div>
    </div>

    {# AI Diagnosis Card #}
    <div style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); border-radius:16px; padding:2rem; color:#fff; margin-bottom:2rem;">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1.5rem;">
            <div>
                <div style="font-size:0.85rem; opacity:0.8; margin-bottom:0.5rem;">Condition détectée</div>
                <h3 style="font-size:1.5rem; font-weight:700; margin:0;">{{ aiResult.condition|default('Non déterminé') }}</h3>
            </div>
            <div style="text-align:right;">
                <div style="background:rgba(255,255,255,0.2); padding:8px 16px; border-radius:12px; margin-bottom:0.5rem;">
                    <span style="font-size:0.75rem; opacity:0.8;">Confiance</span>
                    <div style="font-size:1.2rem; font-weight:600;">{{ aiResult.confidence|default(analyse.aiConfidenceScore) }}</div>
                </div>
                <div style="font-size:0.8rem; opacity:0.7;">
                    {{ analyse.aiDiagnosisDate|date('d/m/Y à H:i') }}
                </div>
            </div>
        </div>

        {# Urgency Badge #}
        <div style="margin-bottom:1.5rem;">
            <span style="background:{% if aiResult.urgency == 'Immédiat' %}#e74c3c{% elseif aiResult.urgency == 'Dans la semaine' %}#f39c12{% else %}#27ae60{% endif %}; 
                         color:#fff; padding:6px 14px; border-radius:20px; font-size:0.85rem; font-weight:500;">
                <i class="fa-solid fa-clock"></i> Urgence: {{ aiResult.urgency|default('Surveiller') }}
            </span>
            {% if aiResult.needsExpert %}
            <span style="background:#e74c3c; color:#fff; padding:6px 14px; border-radius:20px; font-size:0.85rem; font-weight:500; margin-left:0.5rem;">
                <i class="fa-solid fa-user-doctor"></i> Consultation expert recommandée
            </span>
            {% endif %}
        </div>

        {# Action Buttons #}
        <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
            <form method="POST" action="{{ path('expert_analyse_diagnose', {id: analyse.id}) }}" style="display:inline;">
                <button type="submit" style="background:rgba(255,255,255,0.2); color:#fff; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; font-weight:500;">
                    <i class="fa-solid fa-rotate"></i> Relancer le diagnostic
                </button>
            </form>
            <a href="{{ path('expert_analyse_conseil_new', {id: analyse.id}) }}" style="background:#fff; color:#764ba2; text-decoration:none; padding:10px 20px; border-radius:8px; font-weight:500;">
                <i class="fa-solid fa-plus"></i> Créer un conseil basé sur l'IA
            </a>
        </div>
    </div>

    {# Detailed Results #}
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
        
        {# Symptoms #}
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <h4 style="margin:0 0 1rem; color:#1a1a2e; font-size:1rem;">
                <i class="fa-solid fa-heart-pulse" style="color:#e74c3c; margin-right:8px;"></i> Symptômes observés
            </h4>
            <div style="color:#444; line-height:1.7;">
                    {{ aiResult.symptoms is iterable ? aiResult.symptoms|join('\n') : aiResult.symptoms|default('Aucun symptôme spécifique mentionné.')|nl2br }}
            </div>
        </div>

        {# Treatment #}
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <h4 style="margin:0 0 1rem; color:#1a1a2e; font-size:1rem;">
                <i class="fa-solid fa-pills" style="color:#3498db; margin-right:8px;"></i> Traitement recommandé
            </h4>
            <div style="color:#444; line-height:1.7;">
                {{ aiResult.treatment|default('Aucun traitement spécifique mentionné.')|nl2br }}
            </div>
        </div>

        {# Prevention #}
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <h4 style="margin:0 0 1rem; color:#1a1a2e; font-size:1rem;">
                <i class="fa-solid fa-shield-halved" style="color:#27ae60; margin-right:8px;"></i> Prévention
            </h4>
            <div style="color:#444; line-height:1.7;">
                {{ aiResult.prevention|default('Aucune mesure préventive mentionnée.')|nl2br }}
            </div>
        </div>

        {# Image Reference #}
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <h4 style="margin:0 0 1rem; color:#1a1a2e; font-size:1rem;">
                <i class="fa-solid fa-image" style="color:#9b59b6; margin-right:8px;"></i> Image analysée
            </h4>
            {% if analyse.imageUrl %}
                <img src="{{ analyse.imageUrl }}" alt="Image analysée" 
                     style="width:100%; max-height:200px; object-fit:cover; border-radius:8px;"
                     onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
                <div style="display:none; text-align:center; padding:2rem; background:#f8f9fa; border-radius:8px; color:#888;">
                    <i class="fa-solid fa-image" style="font-size:2rem; margin-bottom:0.5rem;"></i>
                    <p>Image non disponible</p>
                </div>
            {% else %}
                <div style="text-align:center; padding:2rem; background:#f8f9fa; border-radius:8px; color:#888;">
                    <i class="fa-solid fa-image" style="font-size:2rem; margin-bottom:0.5rem;"></i>
                    <p>Aucune image</p>
                </div>
            {% endif %}
        </div>
    </div>

    {# Raw Response (Collapsible) #}
    <div style="margin-top:1.5rem; background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
        <details>
            <summary style="cursor:pointer; font-weight:600; color:#1a1a2e; font-size:0.95rem;">
                <i class="fa-solid fa-code" style="color:#7f8c8d; margin-right:8px;"></i> Réponse brute de l'IA
            </summary>
            <div style="margin-top:1rem; padding:1rem; background:#f8f9fa; border-radius:8px; overflow-x:auto;">
                <pre style="margin:0; font-size:0.85rem; color:#444; white-space:pre-wrap; word-break:break-word;">{{ aiResult.rawResponse|default('Aucune réponse brute disponible.') }}</pre>
            </div>
        </details>
    </div>

    {# Disclaimer #}
    <div style="margin-top:1.5rem; padding:1rem; background:#fff3e0; border-radius:8px; border-left:4px solid #f39c12;">
        <div style="display:flex; align-items:flex-start; gap:0.75rem;">
            <i class="fa-solid fa-triangle-exclamation" style="color:#f39c12; margin-top:2px;"></i>
            <div>
                <div style="font-weight:600; color:#1a1a2e; margin-bottom:0.25rem;">Avertissement</div>
                <div style="color:#666; font-size:0.9rem; line-height:1.5;">
                    Ce diagnostic est généré par une intelligence artificielle et ne remplace pas l'expertise d'un professionnel agricole. 
                    Veuillez toujours valider les recommandations avec un expert qualifié avant de prendre des décisions importantes.
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
