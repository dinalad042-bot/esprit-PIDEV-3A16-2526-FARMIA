{% extends 'layouts/admin.html.twig' %}

{% block title %}Informations de l'utilisateur - FarmAI{% endblock %}

{% block body %}
    <div style="display: flex; gap: 12px; margin-bottom: 24px;">
        <a href="{{ path('user_index') }}" class="btn btn-outline-dark"><i class="fas fa-arrow-left"></i> Retour à la liste</a>
    </div>

    <div class="card form-card" style="padding: 40px;">
        <h2 style="margin-top: 0; color: var(--text-dark); margin-bottom: 30px;">Informations de l'utilisateur</h2>

        <form method="post" action="{{ user is defined and user.id ? path('user_edit', {'id': user.id}) : path('user_create') }}">
            <div style="display: flex; gap: 40px; margin-bottom: 30px;">
                <!-- Avatar column -->
                <div style="width: 150px; text-align: center;">
                    <img src="{{ user is defined and user.imageUrl ? user.imageUrl : 'https://ui-avatars.com/api/?name=Nouveau+User&background=random' }}" alt="Profile" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; margin-bottom: 16px; border: 4px solid var(--border-color);">
                    <button type="button" class="btn btn-outline" style="padding: 6px 12px; font-size: 0.85rem; width: 100%;">Choisir Photo</button>
                    <input type="file" style="display:none;" id="avatar_upload">
                </div>

                <!-- Form fields -->
                <div style="flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group">
                        <label for="prenom">Prénom</label>
                        <input type="text" id="prenom" name="prenom" class="form-control" value="{{ user.prenom ?? '' }}" required>
                    </div>
                    <div class="form-group">
                        <label for="nom">Nom</label>
                        <input type="text" id="nom" name="nom" class="form-control" value="{{ user.nom ?? '' }}" required>
                    </div>

                    <div class="form-group" style="grid-column: span 2;">
                        <label for="email">Adresse Email</label>
                        <input type="email" id="email" name="email" class="form-control" value="{{ user.email ?? '' }}" required>
                    </div>

                    <div class="form-group">
                        <label for="telephone">Téléphone</label>
                        <input type="text" id="telephone" name="telephone" class="form-control" value="{{ user.telephone ?? '' }}">
                    </div>

                    <div class="form-group">
                        <label for="role">Rôle</label>
                        <select id="role" name="role" class="form-control">
                            <option value="USER" {% if user is defined and (user.role == 'USER' or not user.role) %}selected{% endif %}>Utilisateur simple</option>
                            <option value="ADMIN" {% if user is defined and user.role == 'ADMIN' %}selected{% endif %}>Administrateur</option>
                            <option value="EXPERT" {% if user is defined and user.role == 'EXPERT' %}selected{% endif %}>Expert</option>
                            <option value="AGRICOLE" {% if user is defined and user.role == 'AGRICOLE' %}selected{% endif %}>Agricole</option>
                            <option value="FOURNISSEUR" {% if user is defined and user.role == 'FOURNISSEUR' %}selected{% endif %}>Fournisseur</option>
                        </select>
                    </div>

                    <div class="form-group" style="grid-column: span 2;">
                        <label for="adresse">Adresse de l'exploitation</label>
                        <input type="text" id="adresse" name="adresse" class="form-control" value="{{ user.adresse ?? '' }}">
                    </div>

                    <div class="form-group" style="grid-column: span 2;">
                        <label for="password">Mot de passe {% if user is defined and user.id %}<span style="color:var(--text-muted); font-weight:normal; font-size: 0.8rem;">(Laissez vide pour conserver l'actuel)</span>{% endif %}</label>
                        <input type="password" id="password" name="password" class="form-control" {% if not user is defined or not user.id %}required{% endif %}>
                    </div>
                </div>
            </div>

            <div style="border-top: 1px solid var(--border-color); padding-top: 24px; display: flex; justify-content: flex-end; gap: 16px;">
                <a href="{{ path('user_index') }}" class="btn btn-outline-dark">Annuler</a>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Enregistrer</button>
            </div>
        </form>
    </div>
{% endblock %}
