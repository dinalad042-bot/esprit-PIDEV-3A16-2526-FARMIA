{% extends 'layouts/admin.html.twig' %}

{% block title %}Gestion des Utilisateurs - FarmAI{% endblock %}

{% block body %}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h1 class="page-title" style="margin: 0;">Gestion des Utilisateurs</h1>
        <div style="display: flex; gap: 12px;">
            <a href="#" class="btn btn-outline-dark"><i class="fas fa-file-excel"></i> Exporter</a>
            <a href="{{ path('user_create') }}" class="btn btn-primary"><i class="fas fa-plus"></i> Ajouter Utilisateur</a>
        </div>
    </div>

    <div class="card" style="padding: 0; overflow: hidden;">
        <div style="padding: 20px; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; background: #fafbfc;">
            <div class="search-bar" style="width: 250px;">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Rechercher par nom..." style="border: 1px solid var(--border-color); box-shadow: none;">
            </div>
            <div>
                <select class="form-control" style="width: auto; padding: 8px 32px 8px 16px; border-radius: 20px;">
                    <option value="">Tous les rôles</option>
                    <option value="ROLE_ADMIN">Admin</option>
                    <option value="ROLE_EXPERT">Expert</option>
                </select>
            </div>
        </div>

        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background-color: #f8f9fa; border-bottom: 2px solid var(--border-color); text-align: left;">
                    <th style="padding: 16px 20px; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">Utilisateur</th>
                    <th style="padding: 16px 20px; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">Email</th>
                    <th style="padding: 16px 20px; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">Rôle</th>
                    <th style="padding: 16px 20px; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">Téléphone</th>
                    <th style="padding: 16px 20px; text-align: right; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for u in users %}
                <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.2s;">
                    <td style="padding: 16px 20px; display: flex; align-items: center;">
                        <img src="{{ u.imageUrl ?? 'https://ui-avatars.com/api/?name=' ~ u.prenom ~ '+' ~ u.nom ~ '&background=random' }}" alt="Avatar" style="width: 36px; height: 36px; border-radius: 50%; margin-right: 12px;">
                        <span style="font-weight: 600;">{{ u.prenom }} {{ u.nom }}</span>
                    </td>
                    <td style="padding: 16px 20px; color: var(--text-muted);">{{ u.email }}</td>
                    <td style="padding: 16px 20px;">
                        <span class="badge {% if u.role == 'ADMIN' %}badge-danger{% elseif u.role == 'EXPERT' %}badge-info{% elseif u.role == 'AGRICOLE' %}badge-warning{% else %}badge-success{% endif %}">
                            {{ u.role }}
                        </span>
                    </td>
                    <td style="padding: 16px 20px; color: var(--text-muted);">{{ u.telephone|default('-') }}</td>
                    <td style="padding: 16px 20px; text-align: right;">
                        <a href="{{ path('user_edit', {'id': u.id}) }}" class="btn btn-outline-dark" style="padding: 6px 10px; font-size: 0.85rem; margin-right: 4px;"><i class="fas fa-edit"></i></a>
                        <form method="post" action="{{ path('api_users_delete', {'id': u.id}) }}" onsubmit="return confirm('Sûr ?');" style="display:inline-block;">
                            <input type="hidden" name="_method" value="DELETE">
                            <button type="submit" class="btn btn-outline-dark" style="padding: 6px 10px; font-size: 0.85rem; color: var(--danger-color); border-color: rgba(244, 67, 54, 0.2);"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" style="padding: 32px; text-align: center; color: var(--text-muted);">Aucun utilisateur trouvé.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
