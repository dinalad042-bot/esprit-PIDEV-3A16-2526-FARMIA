{% extends 'layouts/admin.html.twig' %}
{% block title %}Nouveau Conseil — FarmAI{% endblock %}

{% block body %}
<div style="padding:2rem; max-width:700px;">

    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem;">
        <a href="{{ path('admin_conseil_index') }}" class="btn btn-outline-green">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h2 style="font-size:1.4rem; font-weight:700; color:#1a1a2e; margin:0;">
            <i class="fa-solid fa-plus" style="color:#2ecc71;"></i> Nouveau Conseil
        </h2>
    </div>

    <div style="background:#fff; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.08); padding:2rem;">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <div class="form-group" style="margin-bottom:1.5rem;">
            {{ form_label(form.analyse) }}
            {{ form_errors(form.analyse) }}
            {{ form_widget(form.analyse) }}
        </div>

        <div class="form-group" style="margin-bottom:1.5rem;">
            {{ form_label(form.prioriteRaw) }}
            {{ form_errors(form.prioriteRaw) }}
            {{ form_widget(form.prioriteRaw) }}
        </div>

        <div class="form-group" style="margin-bottom:1.5rem;">
            {{ form_label(form.descriptionConseil) }}
            {{ form_errors(form.descriptionConseil) }}
            {{ form_widget(form.descriptionConseil) }}
        </div>

        <div style="display:flex; gap:1rem; margin-top:1.5rem;">
            <button type="submit" class="btn btn-dark">
                <i class="fa-solid fa-floppy-disk"></i> Enregistrer
            </button>
            <a href="{{ path('admin_conseil_index') }}" class="btn btn-outline-green">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
