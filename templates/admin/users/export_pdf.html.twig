<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Export Utilisateurs - FarmAI</title>
    <style>
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            font-size: 12px;
            color: #334155;
            margin: 0;
            padding: 20px;
        }
        .header {
            text-align: center;
            margin-bottom: 30px;
        }
        .header h1 {
            color: #15803d; /* dark green */
            margin: 0 0 5px 0;
            font-size: 24px;
        }
        .header p {
            margin: 0;
            color: #64748b;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            border-spacing: 0;
        }
        th, td {
            padding: 10px 12px;
            text-align: left;
            border-bottom: 1px solid #e2e8f0;
        }
        th {
            background-color: #16a34a; /* primary green */
            color: #ffffff;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 11px;
            border-bottom: 2px solid #15803d;
        }
        tr:nth-child(even) {
            background-color: #f8fafc;
        }
        .role-badge {
            font-weight: bold;
            font-size: 10px;
            padding: 3px 6px;
            border-radius: 4px;
            background-color: #f1f5f9;
            color: #475569;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>FarmAI - Gestion des Utilisateurs</h1>
        <p>Export généré le {{ "now"|date("d/m/Y à H:i") }} - {{ users|length }} utilisateur(s)</p>
    </div>

    <table>
        <thead>
            <tr>
                <th>Nom</th>
                <th>Prénom</th>
                <th>Email</th>
                <th>CIN</th>
                <th>Téléphone</th>
                <th>Adresse</th>
                <th>Rôle</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
                {% set rawRole = user.role|default('USER')|upper|replace({'ROLE_': ''}) %}
                <tr>
                    <td>{{ user.nom }}</td>
                    <td>{{ user.prenom }}</td>
                    <td>{{ user.email }}</td>
                    <td>{{ user.cin }}</td>
                    <td>{{ user.telephone }}</td>
                    <td>{{ user.adresse }}</td>
                    <td>
                        <span class="role-badge">{{ rawRole }}</span>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>
