{% extends 'layouts/admin.html.twig' %}

{% block title %}Analyse #{{ analyse.id }} — FarmAI{% endblock %}

{% block body %}
<div style="padding:2rem; max-width:900px;">

    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem;">
        <a href="{{ path('admin_analyse_index') }}" class="btn btn-outline-green">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h2 style="font-size:1.4rem; font-weight:700; color:#1a1a2e; margin:0;">
            Analyse <span style="color:#2ecc71;">#{{ analyse.id }}</span>
        </h2>
        <a href="{{ path('admin_analyse_edit', {id: analyse.id}) }}" class="action-btn-edit" style="margin-left:auto;">
            <i class="fa-solid fa-pen"></i> Modifier
        </a>
    </div>

    <div style="display:grid; grid-template-columns:2fr 1fr; gap:1.5rem;">

        {# Main Info #}
        <div style="background:#fff; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.08); padding:2rem;">
            <h3 style="color:#2ecc71; margin-bottom:1rem; font-size:1rem; text-transform:uppercase; letter-spacing:1px;">
                Informations
            </h3>
            <table style="width:100%; border-collapse:collapse;">
                <tr style="border-bottom:1px solid #f0f0f0;">
                    <td style="padding:0.75rem 0; color:#888; width:40%;">Date</td>
                    <td style="padding:0.75rem 0; font-weight:500;">
                        {{ analyse.dateAnalyse ? analyse.dateAnalyse|date('d/m/Y à H:i') : 'N/A' }}
                    </td>
                </tr>
                <tr style="border-bottom:1px solid #f0f0f0;">
                    <td style="padding:0.75rem 0; color:#888;">Ferme</td>
                    <td style="padding:0.75rem 0; font-weight:500;">
                        {{ analyse.ferme ? analyse.ferme.nomFerme~' — '~analyse.ferme.lieu : 'N/A' }}
                    </td>
                </tr>
                <tr style="border-bottom:1px solid #f0f0f0;">
                    <td style="padding:0.75rem 0; color:#888;">Technicien</td>
                    <td style="padding:0.75rem 0; font-weight:500;">
                        {% if analyse.technicien %}
                            {{ analyse.technicien.prenom }} {{ analyse.technicien.nom }}
                            <br><small style="color:#888;">{{ analyse.technicien.email }}</small>
                        {% else %}N/A{% endif %}
                    </td>
                </tr>
                <tr>
                    <td style="padding:0.75rem 0; color:#888; vertical-align:top;">Résultat</td>
                    <td style="padding:0.75rem 0;">
                        <div style="background:#f8f9fa; border-radius:8px; padding:1rem; font-size:0.9rem; line-height:1.6; white-space:pre-wrap;">
                            {{ analyse.resultatTechnique ?? 'Aucun résultat enregistré.' }}
                        </div>
                    </td>
                </tr>
            </table>
        </div>

        {# Side: Image + Stats #}
        <div style="display:flex; flex-direction:column; gap:1rem;">
            {% if analyse.imageUrl %}
            <div style="background:#fff; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.08); padding:1rem; text-align:center;">
                <img src="{{ analyse.imageUrl }}" alt="Image analyse"
                     style="width:100%; border-radius:8px; object-fit:cover; max-height:200px;"
                     onerror="this.src=''; this.alt='Image non disponible'">
            </div>
            {% endif %}
            <div class="stat-card">
                <div style="font-size:2rem; font-weight:700; color:#2ecc71;">{{ analyse.nbConseils }}</div>
                <div style="color:#666; font-size:0.9rem;">Conseil(s) associé(s)</div>
                <a href="{{ path('admin_conseil_index') }}?analyseId={{ analyse.id }}"
                   style="font-size:0.8rem; color:#2ecc71; text-decoration:none;">
                    Voir les conseils →
                </a>
            </div>
        </div>
    </div>

    {# Conseils Section #}
    {% if analyse.conseils|length > 0 %}
    <div style="margin-top:1.5rem; background:#fff; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.08); padding:2rem;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <h3 style="color:#1a1a2e; font-size:1rem; text-transform:uppercase; letter-spacing:1px; margin:0;">
                <i class="fa-solid fa-lightbulb" style="color:#2ecc71;"></i>
                Conseils associés
            </h3>
            <a href="{{ path('admin_conseil_new') }}" class="btn btn-dark" style="font-size:0.85rem;">
                <i class="fa-solid fa-plus"></i> Ajouter
            </a>
        </div>
        {% for conseil in analyse.conseils %}
        <div class="user-row" style="padding:1rem; border-radius:8px; margin-bottom:0.5rem; display:flex; justify-content:space-between; align-items:center;">
            <div>
                <span style="{{ conseil.priorite ? conseil.priorite.badgeStyle() : '' }}">
                    {{ conseil.priorite ? conseil.priorite.icon()~' '~conseil.priorite.label() : 'N/A' }}
                </span>
                <p style="margin:0.5rem 0 0; color:#495057; font-size:0.9rem;">
                    {{ conseil.descriptionConseil|slice(0, 120) }}{% if conseil.descriptionConseil|length > 120 %}...{% endif %}
                </p>
            </div>
            <div style="display:flex; gap:0.5rem; flex-shrink:0; margin-left:1rem;">
                <a href="{{ path('admin_conseil_edit', {id: conseil.id}) }}" class="action-btn-edit">
                    <i class="fa-solid fa-pen"></i>
                </a>
                <form method="POST" action="{{ path('admin_conseil_delete', {id: conseil.id}) }}"
                      onsubmit="return confirm('Supprimer ce conseil ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete'~conseil.id) }}">
                    <button type="submit" class="action-btn-delete">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

</div>
{% endblock %}
