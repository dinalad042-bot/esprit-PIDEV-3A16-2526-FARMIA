<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Rapport d'Analyse #{{ analyse.id }} — FarmAI</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 10pt;
            line-height: 1.5;
            color: #333;
        }
        .header {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            color: white;
            padding: 20px;
            text-align: center;
        }
        .header h1 {
            font-size: 18pt;
            margin-bottom: 5px;
        }
        .header p {
            font-size: 9pt;
            opacity: 0.9;
        }
        .content {
            padding: 20px;
        }
        .section {
            margin-bottom: 20px;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }
        .section-title {
            background: #f8f9fa;
            padding: 10px 15px;
            font-weight: bold;
            font-size: 11pt;
            color: #1a1a2e;
            border-bottom: 1px solid #ddd;
        }
        .section-content {
            padding: 15px;
        }
        .info-row {
            display: flex;
            margin-bottom: 8px;
        }
        .info-label {
            width: 150px;
            color: #666;
            font-weight: 500;
        }
        .info-value {
            flex: 1;
            color: #333;
        }
        .status-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 9pt;
            font-weight: 600;
        }
        .status-en_attente { background: #fff3e0; color: #f39c12; }
        .status-en_cours { background: #e3f2fd; color: #3498db; }
        .status-terminee { background: #e8f8f0; color: #27ae60; }
        .status-annulee { background: #f5f5f5; color: #7f8c8d; }
        .image-container {
            text-align: center;
            margin: 15px 0;
        }
        .image-container img {
            max-width: 100%;
            max-height: 200px;
            border-radius: 8px;
            border: 1px solid #ddd;
        }
        .no-image {
            background: #f5f5f5;
            padding: 40px;
            border-radius: 8px;
            text-align: center;
            color: #999;
        }
        .ai-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 8px;
            padding: 15px;
            margin-top: 20px;
        }
        .ai-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            padding-bottom: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.2);
        }
        .ai-header h3 {
            font-size: 12pt;
        }
        .ai-badge {
            background: rgba(255,255,255,0.2);
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 8pt;
        }
        .ai-content {
            font-size: 9pt;
        }
        .ai-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 10px;
        }
        .ai-box {
            background: rgba(255,255,255,0.1);
            padding: 10px;
            border-radius: 6px;
        }
        .ai-box-title {
            font-size: 8pt;
            opacity: 0.8;
            margin-bottom: 3px;
        }
        .conseil-item {
            border-left: 3px solid;
            padding: 10px 15px;
            margin-bottom: 10px;
            background: #f8f9fa;
            border-radius: 0 6px 6px 0;
        }
        .conseil-haute { border-color: #e74c3c; }
        .conseil-moyenne { border-color: #f39c12; }
        .conseil-basse { border-color: #2ecc71; }
        .conseil-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
        }
        .conseil-id {
            font-weight: bold;
            color: #333;
        }
        .conseil-priorite {
            font-size: 8pt;
            padding: 2px 8px;
            border-radius: 6px;
        }
        .conseil-desc {
            color: #555;
            font-size: 9pt;
        }
        .footer {
            background: #f8f9fa;
            padding: 15px 20px;
            text-align: center;
            font-size: 8pt;
            color: #666;
            border-top: 1px solid #ddd;
            margin-top: 20px;
        }
        .result-box {
            background: #e8f8f0;
            border-left: 4px solid #27ae60;
            padding: 15px;
            border-radius: 0 6px 6px 0;
            margin: 10px 0;
        }
        .result-box h4 {
            color: #27ae60;
            margin-bottom: 8px;
            font-size: 10pt;
        }
        .result-box p {
            color: #444;
            font-size: 9pt;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>FarmAI — Rapport d'Analyse</h1>
        <p>Généré le {{ date|date('d/m/Y à H:i') }}</p>
    </div>

    <div class="content">
        {# Analyse Details #}
        <div class="section">
            <div class="section-title">
                📋 Informations de l'Analyse #{{ analyse.id }}
            </div>
            <div class="section-content">
                <div class="info-row">
                    <div class="info-label">ID Analyse :</div>
                    <div class="info-value">#{{ analyse.id }}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Date d'analyse :</div>
                    <div class="info-value">{{ analyse.dateAnalyse ? analyse.dateAnalyse|date('d/m/Y à H:i') : 'Non définie' }}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Statut :</div>
                    <div class="info-value">
                        <span class="status-badge status-{{ analyse.statut }}">
                            {{ analyse.statut|replace({'_': ' '})|title }}
                        </span>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">Technicien :</div>
                    <div class="info-value">{{ analyse.technicien.prenom }} {{ analyse.technicien.nom }}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Email :</div>
                    <div class="info-value">{{ analyse.technicien.email }}</div>
                </div>
                {% if analyse.ferme %}
                <div class="info-row">
                    <div class="info-label">Ferme :</div>
                    <div class="info-value">{{ analyse.ferme.nomFerme }}</div>
                </div>
                {% if analyse.ferme.lieu %}
                <div class="info-row">
                    <div class="info-label">Lieu :</div>
                    <div class="info-value">{{ analyse.ferme.lieu }}</div>
                </div>
                {% endif %}
                {% endif %}
            </div>
        </div>

        {# Demande Details #}
        <div class="section">
            <div class="section-title">
                📨 Détails de la Demande
            </div>
            <div class="section-content">
                <div class="info-row">
                    <div class="info-label">Demandeur :</div>
                    <div class="info-value">{{ analyse.demandeur.prenom }} {{ analyse.demandeur.nom }}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Email :</div>
                    <div class="info-value">{{ analyse.demandeur.email }}</div>
                </div>
                {% if analyse.animalCible %}
                <div class="info-row">
                    <div class="info-label">Animal concerné :</div>
                    <div class="info-value">{{ analyse.animalCible.nom }}</div>
                </div>
                {% endif %}
                {% if analyse.planteCible %}
                <div class="info-row">
                    <div class="info-label">Plante concernée :</div>
                    <div class="info-value">{{ analyse.planteCible.nom }}</div>
                </div>
                {% endif %}
                {% if analyse.descriptionDemande %}
                <div class="info-row">
                    <div class="info-label">Description :</div>
                    <div class="info-value">{{ analyse.descriptionDemande|nl2br }}</div>
                </div>
                {% endif %}
            </div>
        </div>

        {# Image #}
        {% if analyse.imageUrl %}
        <div class="section">
            <div class="section-title">
                🖼️ Image d'Analyse
            </div>
            <div class="section-content">
                <div class="image-container">
                    <img src="{{ analyse.imageUrl }}" alt="Analyse #{{ analyse.id }}">
                </div>
            </div>
        </div>
        {% endif %}

        {# Résultat Technique #}
        {% if analyse.resultatTechnique %}
        <div class="result-box">
            <h4>📝 Résultat Technique</h4>
            <p>{{ analyse.resultatTechnique|nl2br }}</p>
        </div>
        {% endif %}

        {# AI Diagnosis #}
        {% if analyse.hasAiDiagnosis %}
        {% set aiResult = analyse.aiDiagnosisResult|json_decode %}
        <div class="ai-section">
            <div class="ai-header">
                <h3>🤖 Diagnostic par Intelligence Artificielle</h3>
                <div>
                    <span class="ai-badge">Confiance: {{ analyse.aiConfidenceScore }}</span>
                    <span class="ai-badge">{{ analyse.aiDiagnosisDate|date('d/m/Y H:i') }}</span>
                </div>
            </div>
            <div class="ai-content">
                <div style="background: rgba(255,255,255,0.1); padding: 10px; border-radius: 6px; margin-bottom: 10px;">
                    <strong>Condition détectée :</strong> {{ aiResult.condition|default('Non déterminé') }}
                </div>
                <div class="ai-grid">
                    {% if aiResult.symptoms %}
                    <div class="ai-box">
                        <div class="ai-box-title">🔍 Symptômes</div>
                        <div>{{ aiResult.symptoms }}</div>
                    </div>
                    {% endif %}
                    {% if aiResult.treatment %}
                    <div class="ai-box">
                        <div class="ai-box-title">💊 Traitement recommandé</div>
                        <div>{{ aiResult.treatment }}</div>
                    </div>
                    {% endif %}
                    {% if aiResult.prevention %}
                    <div class="ai-box">
                        <div class="ai-box-title">🛡️ Prévention</div>
                        <div>{{ aiResult.prevention }}</div>
                    </div>
                    {% endif %}
                    {% if aiResult.urgency %}
                    <div class="ai-box">
                        <div class="ai-box-title">⚠️ Urgence</div>
                        <div>{{ aiResult.urgency }}</div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endif %}

        {# Conseils #}
        {% if conseils|length > 0 %}
        <div class="section" style="margin-top: 20px;">
            <div class="section-title">
                💡 Conseils Associés ({{ conseils|length }})
            </div>
            <div class="section-content">
                {% for conseil in conseils %}
                <div class="conseil-item conseil-{{ conseil.prioriteRaw|lower }}">
                    <div class="conseil-header">
                        <span class="conseil-id">Conseil #{{ conseil.id }}</span>
                        <span class="conseil-priorite" style="background: {% if conseil.prioriteRaw == 'HAUTE' %}#ffebee; color: #e74c3c;{% elseif conseil.prioriteRaw == 'MOYENNE' %}#fff3e0; color: #f39c12;{% else %}#e8f8f0; color: #27ae60;{% endif %}">
                            {{ conseil.prioriteRaw|title }}
                        </span>
                    </div>
                    <div class="conseil-desc">{{ conseil.descriptionConseil|nl2br }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>

    <div class="footer">
        <p><strong>FarmAI</strong> — Système d'Intelligence Artificielle pour l'Agriculture</p>
        <p>Ce rapport a été généré automatiquement et est confidentiel.</p>
    </div>
</body>
</html>