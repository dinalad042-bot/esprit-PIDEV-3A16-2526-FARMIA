<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Rapport Analyse #{{ analyse.id }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: DejaVu Sans, sans-serif; font-size: 12px; color: #1a1a2e; line-height: 1.6; }

        .header { background: #2ecc71; color: white; padding: 20px 30px; margin-bottom: 20px; }
        .header h1 { font-size: 20px; font-weight: bold; }
        .header .subtitle { font-size: 11px; opacity: 0.85; margin-top: 4px; }
        .logo { font-size: 24px; font-weight: 900; letter-spacing: -1px; }

        .content { padding: 0 30px; }
        .section { margin-bottom: 20px; }
        .section-title {
            font-size: 11px; font-weight: bold;
            text-transform: uppercase; letter-spacing: 1px;
            color: #2ecc71; border-bottom: 2px solid #2ecc71;
            padding-bottom: 4px; margin-bottom: 12px;
        }

        table.info { width: 100%; border-collapse: collapse; }
        table.info td { padding: 8px 10px; border-bottom: 1px solid #f0f0f0; font-size: 11px; }
        table.info td:first-child { color: #888; width: 35%; font-weight: bold; }

        .result-box {
            background: #f8fffe; border-left: 4px solid #2ecc71;
            padding: 12px; border-radius: 4px; font-size: 11px;
            line-height: 1.7; white-space: pre-wrap;
        }

        .conseil-item {
            border: 1px solid #eee; border-radius: 6px;
            padding: 10px; margin-bottom: 8px;
        }
        .badge {
            display: inline-block; padding: 2px 10px;
            border-radius: 12px; font-size: 10px; font-weight: bold;
            margin-bottom: 6px;
        }
        .badge-haute   { background: #e74c3c; color: white; }
        .badge-moyenne { background: #f39c12; color: white; }
        .badge-basse   { background: #2ecc71; color: white; }

        .footer {
            margin-top: 30px; padding: 15px 30px;
            border-top: 2px solid #f0f0f0;
            font-size: 10px; color: #888;
            display: flex; justify-content: space-between;
        }
        .page-number { text-align: right; }
    </style>
</head>
<body>

    <div class="header">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <div class="logo">🌿 FarmAI</div>
                <h1>Rapport d'Analyse Agricole</h1>
                <div class="subtitle">
                    Généré le {{ date|date('d/m/Y à H:i') }}
                </div>
            </div>
            <div style="text-align:right; font-size:24px; font-weight:900; opacity:0.3;">
                #{{ analyse.id }}
            </div>
        </div>
    </div>

    <div class="content">

        <div class="section">
            <div class="section-title">Informations Générales</div>
            <table class="info">
                <tr>
                    <td>Référence</td>
                    <td>#{{ analyse.id }}</td>
                </tr>
                <tr>
                    <td>Date d'analyse</td>
                    <td>{{ analyse.dateAnalyse ? analyse.dateAnalyse|date('d/m/Y à H:i') : 'N/A' }}</td>
                </tr>
                <tr>
                    <td>Ferme</td>
                    <td>
                        {{ analyse.ferme ? analyse.ferme.nomFerme : 'N/A' }}
                        {% if analyse.ferme %} — {{ analyse.ferme.lieu }}{% endif %}
                    </td>
                </tr>
                <tr>
                    <td>Expert / Technicien</td>
                    <td>
                        {% if analyse.technicien %}
                            {{ analyse.technicien.prenom }} {{ analyse.technicien.nom }}
                            ({{ analyse.technicien.email }})
                        {% else %}N/A{% endif %}
                    </td>
                </tr>
                <tr>
                    <td>Nombre de conseils</td>
                    <td>{{ conseils|length }}</td>
                </tr>
            </table>
        </div>

        {% if analyse.resultatTechnique %}
        <div class="section">
            <div class="section-title">Résultat Technique</div>
            <div class="result-box">{{ analyse.resultatTechnique }}</div>
        </div>
        {% endif %}

        {% if conseils|length > 0 %}
        <div class="section">
            <div class="section-title">Conseils Associés ({{ conseils|length }})</div>
            {% for conseil in conseils %}
            <div class="conseil-item">
                <span class="badge badge-{{ conseil.prioriteRaw|lower }}">
                    {{ conseil.prioriteRaw }}
                </span>
                <div style="font-size:11px; color:#333; line-height:1.6;">
                    {{ conseil.descriptionConseil }}
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

    </div>

    <div class="footer">
        <div>FarmAI Platform — Rapport confidentiel</div>
        <div>ESPRIT PIDEV 3A 2025-2026</div>
    </div>

</body>
</html>
