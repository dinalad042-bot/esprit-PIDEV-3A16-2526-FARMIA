{# templates/components/_splash_screen.html.twig #}
<div id="farmai-splash" class="splash-screen">
    <div class="splash-content">
        <div class="splash-logo-container">
            <!-- Animated minimal SVG Seedling / Leaf -->
            <svg class="splash-plant" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <!-- Soil/Base -->
                <path class="plant-base" pathLength="1" d="M4 22h16"></path>
                <!-- Stem growing up -->
                <path class="plant-stem" pathLength="1" d="M12 22V8"></path>
                <!-- Left leaf growing out of stem -->
                <path class="plant-leaf-left" pathLength="1" d="M12 16C7 16 4 12 4 8c0 0 3-1 8 8z"></path>
                <!-- Right leaf growing out of stem -->
                <path class="plant-leaf-right" pathLength="1" d="M12 12c4 0 7-3 7-7 0 0-3-1-7 7z"></path>
                <!-- Tech pulse circle at top of stem -->
                <circle class="plant-node" cx="12" cy="4" r="2"></circle>
            </svg>
        </div>
        <h1 class="splash-title">Farm<span class="highlight">AI</span></h1>
        <p class="splash-subtitle">Plateforme Agricole Intelligente</p>
    </div>
</div>

<style>
/* Reset any body scrolls during splash */
body:has(.splash-screen:not([style*="display: none"])) {
    overflow: hidden;
}

.splash-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    /* Premium nature-inspired gradient */
    background: linear-gradient(135deg, #022c22 0%, #064e3b 40%, #0f172a 100%);
    z-index: 999999;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    /* Wait 3 seconds, then slide/fade out over 0.6s */
    animation: splashFadeOut 0.6s cubic-bezier(0.16, 1, 0.3, 1) 3s forwards;
}

.splash-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0;
    /* Fade in slightly after load */
    animation: splashFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
}

.splash-logo-container {
    width: 90px;
    height: 90px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 30px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    /* Subtle vertical float */
    animation: logoFloat 4s ease-in-out infinite;
}

/* Glowing backing pulse */
.splash-logo-container::before {
    content: '';
    position: absolute;
    width: 140%;
    height: 140%;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.2) 0%, transparent 60%);
    z-index: 0;
    animation: glowPulse 2s ease-in-out infinite alternate;
}

.splash-plant {
    width: 44px;
    height: 44px;
    color: #34d399; /* Emerald 400 */
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 0 8px rgba(52, 211, 153, 0.5));
}

/* Base drawing */
.plant-base, .plant-stem, .plant-leaf-left, .plant-leaf-right {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: drawPath 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

/* Stagger animations for organic growth */
.plant-base { animation-delay: 0.4s; }
.plant-stem { animation-delay: 0.7s; }
.plant-leaf-left { animation-delay: 1.0s; }
.plant-leaf-right { animation-delay: 1.2s; }

.plant-node {
    opacity: 0;
    transform-origin: center;
    transform: scale(0);
    fill: #10b981;
    animation: nodePop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 1.6s forwards;
}

.splash-title {
    color: white;
    font-size: 3.2rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.04em;
    opacity: 0;
    transform: translateY(20px);
    animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) 1.2s forwards;
}

.splash-title .highlight {
    color: #34d399;
    text-shadow: 0 0 30px rgba(52, 211, 153, 0.4);
}

.splash-subtitle {
    color: #94a3b8;
    font-size: 0.95rem;
    margin-top: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 600;
    opacity: 0;
    transform: translateY(15px);
    animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) 1.4s forwards;
}

/* Keyframes */
@keyframes drawPath {
    to { stroke-dashoffset: 0; }
}

@keyframes nodePop {
    to { opacity: 1; transform: scale(1); }
}

@keyframes splashFadeIn {
    from { opacity: 0; transform: scale(0.97); }
    to { opacity: 1; transform: scale(1); }
}

@keyframes slideUpFade {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

@keyframes logoFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
}

@keyframes glowPulse {
    from { opacity: 0.4; transform: scale(0.85); }
    to { opacity: 1; transform: scale(1.15); }
}

@keyframes splashFadeOut {
    0% { opacity: 1; transform: translateY(0); pointer-events: all; }
    100% { opacity: 0; transform: translateY(-30px); pointer-events: none; visibility: hidden; }
}

/* Very tiny screens */
@media (max-width: 400px) {
    .splash-title { font-size: 2.5rem; }
    .splash-subtitle { font-size: 0.8rem; }
}
</style>
