{% extends 'erp/layout.html.twig' %}
{% block title %}FarmIA Desk — Espace Agriculteur{% endblock %}
{% block body %}
<div class="erp-page-header">
    <h1><i class="fa-solid fa-seedling" style="color:#22c55e;"></i> FarmIA Desk — Production</h1>
</div>

<div class="stats-grid" style="margin-bottom:2rem;">
    <div class="stat-card green">
        <div class="stat-value"><i class="fa-solid fa-cubes"></i></div>
        <div class="stat-label">Matières</div>
        <div class="stat-sublabel">Premières</div>
        <div class="stat-footer stat-footer-line"><a href="{{ path('erp_matiere_index') }}" style="color:#fff;">Gérer →</a></div>
    </div>
    <div class="stat-card">
        <div class="stat-value" style="color:var(--dark-bg);"><i class="fa-solid fa-box-open"></i></div>
        <div class="stat-label" style="color:var(--dark-bg);">Produits finis</div>
        <div class="stat-sublabel">Catalogue</div>
        <div class="stat-footer stat-footer-line" style="color:#cbd5e1;"><a href="{{ path('erp_produit_index') }}" style="color:#334155;">Gérer →</a></div>
    </div>
    <div class="stat-card light-gray">
        <div class="stat-value" style="color:var(--dark-bg);"><i class="fa-solid fa-cart-plus"></i></div>
        <div class="stat-label" style="color:var(--dark-bg);">Achats</div>
        <div class="stat-sublabel">Matières</div>
        <div class="stat-footer stat-footer-line" style="color:#cbd5e1;"><a href="{{ path('erp_achat_index') }}" style="color:#334155;">Gérer →</a></div>
    </div>
    <div class="stat-card dark">
        <div class="stat-value">{{ critiques|length }}</div>
        <div class="stat-label">Alertes</div>
        <div class="stat-sublabel">Stock critique</div>
        <div class="stat-footer stat-footer-line">
            {% if critiques|length > 0 %}<i class="fa-solid fa-triangle-exclamation" style="color:#f59e0b;"></i> Réapprovisionner{% else %}Tout est OK{% endif %}
        </div>
    </div>
</div>

{% if critiques|length > 0 %}
<div class="stock-warning">
    <strong><i class="fa-solid fa-triangle-exclamation"></i> Matières en stock critique</strong>
    <table style="margin-top:.5rem;">
        <tr><th>Matière</th><th>Stock</th><th>Seuil</th><th>Unité</th></tr>
        {% for m in critiques %}
        <tr>
            <td>{{ m.nom }}</td>
            <td><span class="badge-critique">{{ m.stock }}</span></td>
            <td>{{ m.seuilCritique }}</td>
            <td>{{ m.unite }}</td>
        </tr>
        {% endfor %}
    </table>
</div>
{% endif %}

<div class="bottom-grid">
    <div class="action-card">
        <div class="action-header"><h3 class="action-title"><i class="fa-solid fa-bolt"></i> Actions Rapides</h3></div>
        <div class="btn-group">
            <a href="{{ path('erp_matiere_new') }}" class="btn btn-dark"><i class="fa-solid fa-plus"></i> Nouvelle matière</a>
            <a href="{{ path('erp_produit_new') }}" class="btn btn-outline-green"><i class="fa-solid fa-box-open"></i> Nouveau produit</a>
            <a href="{{ path('erp_achat_new') }}" class="btn btn-outline-green"><i class="fa-solid fa-cart-plus"></i> Nouvel achat</a>
        </div>
    </div>
    <div class="enterprise-card">
        <h3 class="enterprise-title"><i class="fa-solid fa-industry"></i> Espace Production</h3>
        <p class="enterprise-text">Gérez vos matières premières, définissez vos recettes de fabrication, enregistrez vos achats et produisez vos produits finis.</p>
        <i class="fa-solid fa-seedling enterprise-icon"></i>
    </div>
</div>
{% endblock %}
