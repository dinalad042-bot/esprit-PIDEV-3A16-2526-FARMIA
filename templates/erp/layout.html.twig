<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}FarmIA Desk — ERP{% endblock %}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('assets/css/dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/profile_modal.css') }}">
    <style>
        .erp-content { padding: 2rem; }
        .erp-page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
        .erp-page-header h1 { font-size: 1.5rem; font-weight: 700; color: var(--dark-bg, #1e293b); margin: 0; }
        .erp-table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
        .erp-table th { background: #f8fafc; padding: .75rem 1rem; text-align: left; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; color: #64748b; border-bottom: 1px solid #e2e8f0; }
        .erp-table td { padding: .75rem 1rem; border-bottom: 1px solid #f1f5f9; font-size: .9rem; color: #334155; }
        .erp-table tr:last-child td { border-bottom: none; }
        .erp-table tr:hover td { background: #f8fafc; }
        .badge-critique { background: #fef2f2; color: #dc2626; padding: .2rem .6rem; border-radius: 999px; font-size: .75rem; font-weight: 600; }
        .badge-ok { background: #f0fdf4; color: #16a34a; padding: .2rem .6rem; border-radius: 999px; font-size: .75rem; font-weight: 600; }
        .btn-erp { display: inline-flex; align-items: center; gap: .4rem; padding: .45rem .9rem; border-radius: 8px; font-size: .85rem; font-weight: 600; cursor: pointer; border: none; text-decoration: none; transition: opacity .15s; }
        .btn-erp:hover { opacity: .85; }
        .btn-primary { background: #22c55e; color: #fff; }
        .btn-danger { background: #ef4444; color: #fff; }
        .btn-secondary { background: #e2e8f0; color: #334155; }
        .btn-warning { background: #f59e0b; color: #fff; }
        .alert-erp { padding: .75rem 1rem; border-radius: 8px; margin-bottom: 1rem; font-size: .9rem; }
        .alert-erp.success { background: #f0fdf4; color: #166534; border-left: 4px solid #22c55e; }
        .alert-erp.error { background: #fef2f2; color: #991b1b; border-left: 4px solid #ef4444; }
        .alert-erp.warning { background: #fffbeb; color: #92400e; border-left: 4px solid #f59e0b; }
        .erp-form-card { background: #fff; border-radius: 12px; padding: 1.5rem; box-shadow: 0 1px 4px rgba(0,0,0,.08); max-width: 700px; }
        .erp-form-card .form-group { margin-bottom: 1rem; }
        .erp-form-card label { display: block; font-size: .85rem; font-weight: 600; color: #475569; margin-bottom: .3rem; }
        .erp-form-card input, .erp-form-card textarea, .erp-form-card select { width: 100%; padding: .5rem .75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: .9rem; color: #334155; box-sizing: border-box; }
        .erp-form-card input:focus, .erp-form-card textarea:focus, .erp-form-card select:focus { outline: none; border-color: #22c55e; box-shadow: 0 0 0 3px rgba(34,197,94,.15); }
        .ligne-row { display: grid; grid-template-columns: 2fr 1fr 1fr auto; gap: .75rem; align-items: end; margin-bottom: .75rem; padding: .75rem; background: #f8fafc; border-radius: 8px; }
        .ligne-row .sous-total { font-weight: 700; color: #22c55e; font-size: .9rem; padding-top: 1.5rem; }
        .total-display { font-size: 1.2rem; font-weight: 700; color: #1e293b; margin-top: 1rem; padding: .75rem 1rem; background: #f0fdf4; border-radius: 8px; display: inline-block; }
        .convert-section { margin-top: 1.5rem; padding: 1rem; background: #f8fafc; border-radius: 8px; }
        .convert-section h4 { margin: 0 0 .75rem; font-size: .95rem; color: #475569; }
        .convert-row { display: flex; gap: .75rem; align-items: center; flex-wrap: wrap; }
        .convert-result { margin-top: .5rem; font-weight: 600; color: #0f172a; }
        .stock-warning { background: #fffbeb; border: 1px solid #fcd34d; border-radius: 8px; padding: .75rem 1rem; margin-bottom: 1rem; }
        .stock-warning table { width: 100%; font-size: .85rem; }
        .stock-warning th { color: #92400e; padding: .3rem .5rem; }
        .stock-warning td { padding: .3rem .5rem; color: #78350f; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <aside class="sidebar">
        <div class="profile-card" onclick="openProfileModal()" style="cursor: pointer;">
            <div class="profile-img-wrapper" style="overflow: hidden; border-radius: 50%;">
                {% include 'components/_avatar.html.twig' with {'user': app.user, 'size': '100%', 'fontSize': '1.2rem'} %}
            </div>
            <i class="fa-solid fa-ellipsis profile-ellipsis"></i>
            <div class="profile-info">
                <div class="profile-name">{{ app.user.prenom|default('Utilisateur') }} {{ app.user.nom|default('') }}</div>
                <div class="profile-role">
                    {% if is_granted('ROLE_AGRICOLE') %}Agriculteur{% else %}Fournisseur{% endif %}
                </div>
            </div>
        </div>

        {% set current_route = app.request.attributes.get('_route') %}

        <ul class="nav-menu">
            {# Home link — role-specific portal #}
            {% if is_granted('ROLE_AGRICOLE') %}
            <li class="nav-item">
                <a href="{{ path('dashboard_agricole') }}" class="{% if current_route == 'dashboard_agricole' %}active{% endif %}">
                    <i class="fa-solid fa-house"></i><span>Tableau de bord</span>
                </a>
            </li>
            {% else %}
            <li class="nav-item">
                <a href="{{ path('dashboard_fournisseur') }}" class="{% if current_route == 'dashboard_fournisseur' %}active{% endif %}">
                    <i class="fa-solid fa-house"></i><span>Tableau de bord</span>
                </a>
            </li>
            {% endif %}

            <li class="nav-item">
                <a href="{{ path('erp_dashboard') }}" class="{% if current_route starts with 'erp_' %}active{% endif %}">
                    <i class="fa-solid fa-store"></i><span>FarmIA Desk ERP</span>
                </a>
            </li>

            {% if current_route starts with 'erp_' %}
                {# AGRICOLE: Matières + Produits + Achats #}
                {% if is_granted('ROLE_AGRICOLE') %}
                <li class="nav-item" style="padding-left:1rem;">
                    <a href="{{ path('erp_matiere_index') }}" class="{% if current_route starts with 'erp_matiere' %}active{% endif %}">
                        <i class="fa-solid fa-cubes"></i><span>Matières premières</span>
                    </a>
                </li>
                <li class="nav-item" style="padding-left:1rem;">
                    <a href="{{ path('erp_produit_index') }}" class="{% if current_route starts with 'erp_produit' %}active{% endif %}">
                        <i class="fa-solid fa-box-open"></i><span>Produits finis</span>
                    </a>
                </li>
                <li class="nav-item" style="padding-left:1rem;">
                    <a href="{{ path('erp_achat_index') }}" class="{% if current_route starts with 'erp_achat' %}active{% endif %}">
                        <i class="fa-solid fa-cart-plus"></i><span>Achats</span>
                    </a>
                </li>
                {% endif %}

                {# FOURNISSEUR: Produit catalogue (read-only) + Ventes #}
                {% if is_granted('ROLE_FOURNISSEUR') %}
                <li class="nav-item" style="padding-left:1rem;">
                    <a href="{{ path('erp_produit_index') }}" class="{% if current_route starts with 'erp_produit' %}active{% endif %}">
                        <i class="fa-solid fa-box-open"></i><span>Catalogue produits</span>
                    </a>
                </li>
                <li class="nav-item" style="padding-left:1rem;">
                    <a href="{{ path('erp_vente_index') }}" class="{% if current_route starts with 'erp_vente' %}active{% endif %}">
                        <i class="fa-solid fa-receipt"></i><span>Ventes</span>
                    </a>
                </li>
                {% endif %}
            {% endif %}

            <li class="nav-item">
                <a href="#" onclick="openProfileModal(); return false;">
                    <i class="fa-solid fa-user"></i><span>Mon Profil</span>
                </a>
            </li>
        </ul>

        <div class="logout-container">
            <a href="{{ path('app_logout') }}">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                <span>Déconnexion</span>
            </a>
        </div>
    </aside>

    <main class="main-content">
        <header class="topbar">
            <div class="brand-title">FarmIA Desk — ERP</div>
            <div class="topbar-right">
                <a href="{{ is_granted('ROLE_AGRICOLE') ? path('dashboard_agricole') : path('dashboard_fournisseur') }}" class="btn-erp btn-secondary" style="font-size:.8rem;">
                    <i class="fa-solid fa-arrow-left"></i> Retour portail
                </a>
                <div class="topbar-avatar" style="display:flex;align-items:center;justify-content:center;cursor:pointer;overflow:hidden;border-radius:50%;" onclick="openProfileModal()">
                    {% include 'components/_avatar.html.twig' with {'user': app.user, 'size': '100%', 'fontSize': '1rem'} %}
                </div>
            </div>
        </header>

        <div class="erp-content">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert-erp {{ type }}">
                        <i class="fa-solid {% if type == 'success' %}fa-circle-check{% elseif type == 'error' %}fa-circle-xmark{% else %}fa-triangle-exclamation{% endif %}"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>
    </main>

    {% include 'components/_profile_modal.html.twig' %}
    {% block javascripts %}{% endblock %}
</body>
</html>
