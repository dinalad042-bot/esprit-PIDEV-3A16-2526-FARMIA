{% extends 'erp/layout.html.twig' %}
{% block title %}Ventes — FarmIA Desk{% endblock %}

{% block stylesheets %}
<style>
.cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
    padding: .25rem 0;
}
.order-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,.08);
    transition: transform .15s, box-shadow .15s;
    display: flex;
    flex-direction: column;
}
.order-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,.12); }
.order-card-img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    background: #e2e8f0;
    display: block;
}
.order-card-img-placeholder {
    width: 100%;
    height: 160px;
    background: linear-gradient(135deg, #6d28d9 0%, #22c55e 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: rgba(255,255,255,.6);
}
.order-card-body { padding: 1rem; flex: 1; display: flex; flex-direction: column; gap: .5rem; }
.order-card-header { display: flex; align-items: center; justify-content: space-between; }
.order-card-id { font-size: .75rem; color: #94a3b8; font-weight: 600; }
.order-card-date { font-size: .8rem; color: #64748b; }
.order-card-lines { flex: 1; }
.order-card-line { font-size: .8rem; color: #475569; padding: .2rem 0; border-bottom: 1px solid #f1f5f9; }
.order-card-line:last-child { border-bottom: none; }
.order-card-total { font-size: 1.1rem; font-weight: 700; color: #6d28d9; margin-top: .25rem; }
.order-card-consumed { font-size: .75rem; color: #94a3b8; margin-top: .25rem; }
.order-card-footer { padding: .75rem 1rem; border-top: 1px solid #f1f5f9; display: flex; gap: .5rem; align-items: center; }
.empty-state { text-align: center; padding: 4rem 2rem; color: #94a3b8; }
.empty-state i { font-size: 3rem; margin-bottom: 1rem; display: block; }
</style>
{% endblock %}

{% block body %}
<div class="erp-page-header">
    <h1><i class="fa-solid fa-receipt" style="color:#22c55e;"></i> Ventes de produits</h1>
    <a href="{{ path('erp_vente_new') }}" class="btn-erp btn-primary"><i class="fa-solid fa-plus"></i> Nouvelle vente</a>
</div>

{% if ventes|length == 0 %}
<div class="empty-state">
    <i class="fa-solid fa-receipt"></i>
    <p>Aucune vente enregistrée.</p>
    <a href="{{ path('erp_vente_new') }}" class="btn-erp btn-primary" style="margin-top:1rem;">
        <i class="fa-solid fa-plus"></i> Créer la première vente
    </a>
</div>
{% else %}
<div class="cards-grid">
    {% for v in ventes %}
    {% set firstLigne = v.lignes|first %}
    {% set imgSeed = v.idVente %}
    <div class="order-card">
        <img class="order-card-img"
             src="https://picsum.photos/seed/vente{{ imgSeed }}/600/320"
             alt="vente"
             onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
        <div class="order-card-img-placeholder" style="display:none;">
            <i class="fa-solid fa-receipt"></i>
        </div>

        <div class="order-card-body">
            <div class="order-card-header">
                <span class="order-card-id">#{{ v.idVente }}</span>
                <span class="order-card-date"><i class="fa-regular fa-calendar"></i> {{ v.dateVente|date('d/m/Y') }}</span>
            </div>

            <div class="order-card-lines">
                {% for l in v.lignes %}
                <div class="order-card-line">
                    <i class="fa-solid fa-box-open" style="color:#6d28d9;font-size:.7rem;"></i>
                    {{ l.produit.nom }} × {{ l.quantite }}
                    <span style="float:right;font-weight:600;">{{ l.sousTotal|number_format(2,',',' ') }} €</span>
                </div>
                {% endfor %}
            </div>

            {# Show consumed matieres summary #}
            {% set consumed = [] %}
            {% for l in v.lignes %}
                {% for ing in l.produit.recette %}
                    {% set consumed = consumed|merge([ing.quantite * l.quantite ~ ' ' ~ ing.matiere.unite ~ ' ' ~ ing.matiere.nom]) %}
                {% endfor %}
            {% endfor %}
            {% if consumed|length > 0 %}
            <div class="order-card-consumed">
                <i class="fa-solid fa-cubes" style="color:#f59e0b;"></i>
                Consommé : {{ consumed|join(', ') }}
            </div>
            {% endif %}

            <div class="order-card-total">
                <i class="fa-solid fa-coins"></i> {{ v.total|number_format(2,',',' ') }} €
            </div>
        </div>

        <div class="order-card-footer">
            <form method="post" action="{{ path('erp_vente_delete', {id: v.idVente}) }}"
                  onsubmit="return confirm('Supprimer ? Les matières seront restituées.')"
                  style="width:100%;">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_vente_' ~ v.idVente) }}">
                <button type="submit" class="btn-erp btn-danger" style="width:100%;">
                    <i class="fa-solid fa-trash"></i> Supprimer
                </button>
            </form>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
