{% extends 'layouts/admin.html.twig' %}
{% block title %}Mes Analyses — FarmAI{% endblock %}

{% block body %}
<div style="padding:2rem;">

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
        <div>
            <h2 style="font-size:1.5rem; font-weight:700; color:#1a1a2e; margin:0;">
                <i class="fa-solid fa-flask" style="color:#2ecc71;"></i>
                Analyses Agricoles
            </h2>
            <p style="color:#888; margin:0.25rem 0 0; font-size:0.9rem;">
                Consultez et gérez vos analyses de terrain
            </p>
        </div>
        <a href="{{ path('app_analyse_new') }}" class="btn btn-dark">
            <i class="fa-solid fa-plus"></i> Nouvelle Analyse
        </a>
    </div>

    {# Search #}
    <form method="GET" style="margin-bottom:1.5rem; display:flex; gap:0.5rem;">
        <input type="text" name="search" value="{{ search }}"
               placeholder="Rechercher dans les résultats techniques..."
               class="form-control" style="max-width:400px;">
        <button type="submit" class="btn btn-dark">
            <i class="fa-solid fa-magnifying-glass"></i>
        </button>
        {% if search %}
            <a href="{{ path('app_analyse_index') }}" class="btn btn-secondary">
                <i class="fa-solid fa-xmark"></i>
            </a>
        {% endif %}
    </form>

    {# Stats #}
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:1.5rem;">
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06); border-left:4px solid #2ecc71;">
            <div style="font-size:2rem; font-weight:700; color:#2ecc71;">{{ analyses|length }}</div>
            <div style="color:#666; font-size:0.9rem; margin-top:0.25rem;">Total analyses</div>
        </div>
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06); border-left:4px solid #3498db;">
            <div style="font-size:2rem; font-weight:700; color:#3498db;">
                {{ analyses|filter(a => a.nbConseils > 0)|length }}
            </div>
            <div style="color:#666; font-size:0.9rem; margin-top:0.25rem;">Avec conseils</div>
        </div>
        <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.06); border-left:4px solid #e74c3c;">
            <div style="font-size:2rem; font-weight:700; color:#e74c3c;">
                {{ analyses|filter(a => a.nbConseils == 0)|length }}
            </div>
            <div style="color:#666; font-size:0.9rem; margin-top:0.25rem;">Sans conseils</div>
        </div>
    </div>

    {# Cards Grid #}
    {% if analyses|length == 0 %}
        <div style="text-align:center; padding:4rem; background:#fff; border-radius:12px; color:#aaa;">
            <i class="fa-solid fa-flask" style="font-size:3rem; margin-bottom:1rem; display:block;"></i>
            <p style="font-size:1.1rem;">Aucune analyse trouvée.</p>
            <a href="{{ path('app_analyse_new') }}" class="btn btn-dark" style="margin-top:1rem;">
                Créer la première analyse
            </a>
        </div>
    {% else %}
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(320px,1fr)); gap:1.5rem;">
            {% for analyse in analyses %}
            <div style="background:#fff; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.06); overflow:hidden; transition:transform 0.2s;"
                 onmouseover="this.style.transform='translateY(-3px)'"
                 onmouseout="this.style.transform='translateY(0)'">

                {# Image Header #}
                {% if analyse.imageUrl %}
                    <img src="{{ analyse.imageUrl }}" alt="Analyse"
                         style="width:100%; height:160px; object-fit:cover;"
                         onerror="this.style.display='none'">
                {% else %}
                    <div style="width:100%; height:100px; background:linear-gradient(135deg,#2ecc71,#27ae60); display:flex; align-items:center; justify-content:center;">
                        <i class="fa-solid fa-flask" style="color:rgba(255,255,255,0.6); font-size:2.5rem;"></i>
                    </div>
                {% endif %}

                <div style="padding:1.25rem;">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:0.75rem;">
                        <span style="color:#2ecc71; font-weight:700; font-size:0.9rem;">
                            #{{ analyse.id }}
                        </span>
                        <span style="background:#e8f8f0; color:#27ae60; padding:2px 10px; border-radius:12px; font-size:0.78rem;">
                            {{ analyse.nbConseils }} conseil(s)
                        </span>
                    </div>

                    <div style="color:#888; font-size:0.82rem; margin-bottom:0.5rem;">
                        <i class="fa-solid fa-calendar" style="margin-right:4px;"></i>
                        {{ analyse.dateAnalyse ? analyse.dateAnalyse|date('d/m/Y') : 'N/A' }}
                    </div>

                    {% if analyse.ferme %}
                    <div style="color:#555; font-size:0.85rem; margin-bottom:0.5rem;">
                        <i class="fa-solid fa-map-marker-alt" style="color:#2ecc71; margin-right:4px;"></i>
                        {{ analyse.ferme.nomFerme }}
                    </div>
                    {% endif %}

                    {% if analyse.resultatTechnique %}
                    <p style="color:#666; font-size:0.85rem; line-height:1.5; margin:0.75rem 0;">
                        {{ analyse.resultatTechnique|slice(0, 100) }}{% if analyse.resultatTechnique|length > 100 %}...{% endif %}
                    </p>
                    {% endif %}

                    <div style="display:flex; gap:0.5rem; margin-top:1rem; padding-top:1rem; border-top:1px solid #f0f0f0;">
                        <a href="{{ path('app_analyse_show', {id: analyse.id}) }}"
                           style="flex:1; text-align:center; background:#2ecc71; color:#fff; padding:8px; border-radius:8px; text-decoration:none; font-size:0.85rem;">
                            <i class="fa-solid fa-eye"></i> Voir
                        </a>
                        <a href="{{ path('app_analyse_edit', {id: analyse.id}) }}"
                           style="flex:1; text-align:center; background:#f0f0f0; color:#333; padding:8px; border-radius:8px; text-decoration:none; font-size:0.85rem;">
                            <i class="fa-solid fa-pen"></i> Modifier
                        </a>
                        <form method="POST" action="{{ path('app_analyse_delete', {id: analyse.id}) }}"
                              onsubmit="return confirm('Supprimer cette analyse ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete'~analyse.id) }}">
                            <button type="submit"
                                    style="background:#fff0f0; color:#e74c3c; border:none; padding:8px 12px; border-radius:8px; cursor:pointer; font-size:0.85rem;">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}