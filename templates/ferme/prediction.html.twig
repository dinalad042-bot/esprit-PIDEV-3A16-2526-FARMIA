{% extends 'layouts/agricole.html.twig' %}

{% block title %}Rapport IA - {{ ferme.nomFerme }}{% endblock %}

{% block body %}
<style>
    /* --- STYLE POUR L'ÉCRAN --- */
    .report-paper {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.05);
        padding: 50px;
        position: relative;
        border: 1px solid #e2e8f0;
    }

    .ai-content {
        line-height: 1.8;
        color: #334155;
        font-size: 1.1rem;
        white-space: pre-wrap;
    }

    /* --- LOGIQUE D'IMPRESSION (MAGIE ICI) --- */
    @media print {
        /* 1. On cache TOUT ce qui appartient au layout (sidebar, navbar, footer) */
        /* Note : Remplace ces sélecteurs par les vraies classes de ton layout si nécessaire */
        nav, .sidebar, .navbar, aside, footer, .no-print {
            display: none !important;
        }

        /* 2. On réinitialise les marges du body pour l'impression */
        body {
            background: white !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        /* 3. On force le bloc rouge (ton rapport) à occuper TOUTE la page */
        .printable-area {
            position: absolute;
            left: 0;
            top: 0;
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            box-shadow: none !important;
            border: none !important;
        }

        /* Optionnel : Ajuster la taille de la police pour le PDF */
        .ai-content {
            font-size: 12pt !important;
        }
    }
</style>

<div style="max-width: 1000px; margin: 40px auto; padding: 0 20px;">

    {# Boutons d'action (cachés au PDF) #}
    <div class="no-print" style="display: flex; justify-content: space-between; margin-bottom: 25px;">
        <a href="{{ path('app_ferme_index') }}" style="text-decoration: none; color: #64748b; font-weight: 600; display: flex; align-items: center; gap: 8px;">
            <i class="fa-solid fa-arrow-left"></i> Retour
        </a>
        <button onclick="window.print()" style="background: #059669; color: white; border: none; padding: 12px 25px; border-radius: 12px; font-weight: 700; cursor: pointer; box-shadow: 0 4px 12px rgba(5,150,105,0.2);">
            <i class="fa-solid fa-print"></i> Imprimer le rapport
        </button>
    </div>

    {# --- LE CHAMP ENTOURÉ EN ROUGE (PRINTABLE AREA) --- #}
    <div class="report-paper printable-area">
        
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px;">
            <div>
                <span style="background: #ecfdf5; color: #059669; padding: 6px 12px; border-radius: 8px; font-weight: 700; font-size: 0.75rem; text-transform: uppercase;">
                    <i class="fa-solid fa-robot"></i> Analyse Smart-Farming
                </span>
                <h1 style="margin: 15px 0 5px 0; color: #1e293b; font-size: 2.4rem; font-weight: 800;">Plan Prédictif : {{ ferme.nomFerme }}</h1>
                <div style="display: flex; gap: 20px; color: #64748b;">
                    <span><i class="fa-solid fa-location-dot" style="color: #059669;"></i> {{ ferme.lieu }}</span>
                    <span><i class="fa-solid fa-maximize" style="color: #059669;"></i> {{ ferme.surface }} m²</span>
                </div>
            </div>
            <div style="text-align: right;">
                <p style="margin: 0; color: #94a3b8; font-size: 0.8rem;">Date du rapport</p>
                <p style="margin: 0; font-weight: 700;">{{ "now"|date("d/m/Y") }}</p>
            </div>
        </div>

        <div style="background: #f8fafc; border-radius: 16px; padding: 35px; border-left: 6px solid #059669;">
            <h3 style="margin-top: 0; color: #1e293b; display: flex; align-items: center; gap: 12px;">
                <i class="fa-solid fa-wand-magic-sparkles" style="color: #059669;"></i> Recommandations de l'IA
            </h3>
            <div class="ai-content">
                {{ plan|raw }}
            </div>
        </div>

        {# Footer discret pour le PDF #}
        <div style="margin-top: 50px; text-align: center; border-top: 1px solid #f1f5f9; padding-top: 20px;">
            <p style="color: #94a3b8; font-size: 0.8rem; font-style: italic;">
                Rapport généré numériquement par FarmAI Platform pour {{ ferme.nomFerme }}.
            </p>
        </div>
    </div>
</div>
{% endblock %}