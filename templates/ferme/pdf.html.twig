<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Liste des Fermes</title>
    <style>
        body { font-family: sans-serif; }
        h1 { color: #2d7a36; text-align: center; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background-color: #f1f5f9; color: #1e293b; }
        .surface { font-weight: bold; color: #1e40af; }
    </style>
</head>
<body>
    <h1>Rapport des Exploitations - FarmAI</h1>
    <p>Généré le : {{ "now"|date("d/m/Y H:i") }}</p>

    <table>
        <thead>
            <tr>
                <th>Nom de la Ferme</th>
                <th>Lieu</th>
                <th>Surface (m²)</th>
            </tr>
        </thead>
        <tbody>
            {% for ferme in fermes %}
                <tr>
                    <td>{{ ferme.nomFerme }}</td>
                    <td>{{ ferme.lieu }}</td>
                    <td class="surface">{{ ferme.surface }} m²</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>