<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}FarmAI{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="{{ asset('assets/css/auth.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="auth-layout">
        <!-- Panel gauche (Vert) -->
        <div class="left-panel">
            <div class="logo-icon"><i class="fas fa-seedling"></i></div>
            <h1>FarmAI</h1>
            <h2>{% block left_subtitle %}Agriculture Intelligente{% endblock %}</h2>

            <ul style="margin-top: 20px;">
                {% block left_features %}
                    <li>Gestion optimisée des cultures</li>
                    <li>Analyse IA avancée</li>
                    <li>Suivi en temps réel</li>
                {% endblock %}
            </ul>
        </div>

        <!-- Panel droite (Formulaire) -->
        <div class="right-panel">
            <div class="auth-box">
                
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">
                        {{ message }}
                    </div>
                {% endfor %}

                {% for message in app.flashes('error') %}
                    <div class="alert alert-error">
                        {{ message }}
                    </div>
                {% endfor %}

                {% block auth_content %}{% endblock %}
            </div>
        </div>
    </div>
    {% block scripts %}{% endblock %}
</body>
</html>
