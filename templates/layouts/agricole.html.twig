<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}FarmAI Agricole{% endblock %}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('assets/css/dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/profile_modal.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <aside class="sidebar">
        <div class="profile-card" onclick="openProfileModal()" style="cursor: pointer;">
            <div class="profile-img-wrapper" style="overflow: hidden; border-radius: 50%;">
                {% include 'components/_avatar.html.twig' with {'user': app.user, 'size': '100%', 'fontSize': '1.2rem'} %}
            </div>
            <i class="fa-solid fa-ellipsis profile-ellipsis"></i>
            <div class="profile-info">
                <div class="profile-name">{{ app.user.prenom|default('Agriculteur') }} {{ app.user.nom|default('') }}</div>
                <div class="profile-role">Agricole</div>
            </div>
        </div>

        {% set current_route = app.request.attributes.get('_route') %}

        <ul class="nav-menu">
            <li class="nav-item">
                <a href="{{ path('dashboard_agricole') }}" class="{% if current_route == 'dashboard_agricole' %}active{% endif %}">
                    <i class="fa-solid fa-house"></i>
                    <span>Tableau de bord</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="#" onclick="openProfileModal(); return false;">
                    <i class="fa-solid fa-user"></i>
                    <span>Mon Profil</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('app_ferme_index') }}" class="{% if current_route starts with 'app_ferme' %}active{% endif %}">
                    <i class="fa-solid fa-tractor"></i>
                    <span>Mes Fermes</span>
                </a>
            </li>
            <li class="nav-item">
                {# NAVIGATION MISE À JOUR : On pointe vers le menu Hub (3 cartes) #}
                <a href="{{ path('app_exploitation_menu') }}" class="{% if current_route == 'app_exploitation_menu' %}active{% endif %}">
                    <i class="fa-solid fa-leaf"></i>
                    <span>Cultures</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('farmer_my_requests') }}" class="{% if current_route starts with 'farmer' %}active{% endif %}">
                    <i class="fa-solid fa-flask"></i>
                    <span>Mes Analyses</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('app_animal_index') }}" class="{% if current_route starts with 'app_animal' %}active{% endif %}">
                    <i class="fa-solid fa-cow"></i>
                    <span>Animaux</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('erp_dashboard') }}" class="{% if current_route starts with 'erp_' %}active{% endif %}">
                    <i class="fa-solid fa-industry"></i>
                    <span>Production ERP</span>
                </a>
            </li>
            {% if current_route starts with 'erp_' %}
            <li class="nav-item" style="padding-left:1rem;">
                <a href="{{ path('erp_matiere_index') }}" class="{% if current_route starts with 'erp_matiere' %}active{% endif %}">
                    <i class="fa-solid fa-cubes"></i><span>Matières</span>
                </a>
            </li>
            <li class="nav-item" style="padding-left:1rem;">
                <a href="{{ path('erp_produit_index') }}" class="{% if current_route starts with 'erp_produit' %}active{% endif %}">
                    <i class="fa-solid fa-box-open"></i><span>Produits finis</span>
                </a>
            </li>
            <li class="nav-item" style="padding-left:1rem;">
                <a href="{{ path('erp_achat_index') }}" class="{% if current_route starts with 'erp_achat' %}active{% endif %}">
                    <i class="fa-solid fa-cart-plus"></i><span>Achats</span>
                </a>
            </li>
            {% endif %}
        </ul>

        <div class="logout-container">
            <a href="{{ path('app_logout') }}">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                <span>Déconnexion</span>
            </a>
        </div>
    </aside>

    <main class="main-content">
        <header class="topbar">
            <div class="brand-title">FarmAI Platform</div>
            <div class="topbar-right">
                <div class="search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Rechercher...">
                </div>
                <div class="topbar-avatar" style="display: flex; align-items: center; justify-content: center; cursor: pointer; overflow: hidden; border-radius: 50%;" onclick="openProfileModal()">
                    {% include 'components/_avatar.html.twig' with {'user': app.user, 'size': '100%', 'fontSize': '1rem'} %}
                </div>
            </div>
        </header>

        {% block body %}{% endblock %}
    </main>

    {% include 'components/_profile_modal.html.twig' %}
    {% include 'components/_chatbot.html.twig' %}
    {% block javascripts %}{% endblock %}
</body>
</html>