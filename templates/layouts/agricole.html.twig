<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}FarmAI Agricole{% endblock %}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('assets/css/dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/profile_modal.css') }}">
    {% block stylesheets %}{% endblock %}

    <style>
        /* --- PERSISTANCE ET NETTOYAGE GOOGLE --- */
        .goog-te-banner-frame.skiptranslate { display: none !important; }
        body { top: 0px !important; }

        /* --- STYLE DU BOUTON FLOTTANT (TOUJOURS PRÉSENT) --- */
        .translate-floating-btn {
            position: fixed;
            bottom: 25px;
            right: 25px;
            z-index: 9999;
            background: #10b981; /* Vert FarmAI */
            color: white;
            padding: 12px;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid white;
        }

        .translate-floating-btn:hover {
            transform: scale(1.05);
            background: #059669;
        }

        .translate-floating-btn i {
            font-size: 1.4rem;
            margin-right: 8px;
        }

        /* Masquer le texte par défaut de Google et ne garder que le sélecteur */
        #google_translate_element {
            display: inline-block;
        }

        .goog-te-gadget-simple {
            background-color: transparent !important;
            border: none !important;
            padding: 0 !important;
            font-family: 'Inter', sans-serif !important;
        }

        .goog-te-menu-value span {
            color: white !important; /* Texte en blanc sur le bouton vert */
            font-weight: 600 !important;
            font-size: 0.85rem !important;
            text-transform: uppercase;
        }

        .goog-te-gadget-icon { display: none !important; }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="profile-card" onclick="openProfileModal()" style="cursor: pointer;">
            <div class="profile-img-wrapper" style="overflow: hidden; border-radius: 50%;">
                {% include 'components/_avatar.html.twig' with {'user': app.user, 'size': '100%', 'fontSize': '1.2rem'} %}
            </div>
            <i class="fa-solid fa-ellipsis profile-ellipsis"></i>
            <div class="profile-info">
                <div class="profile-name">{{ app.user.prenom|default('Agriculteur') }} {{ app.user.nom|default('') }}</div>
                <div class="profile-role">Agricole</div>
            </div>
        </div>

        {% set current_route = app.request.attributes.get('_route') %}

        <ul class="nav-menu">
            <li class="nav-item">
                <a href="{{ path('dashboard_agricole') }}" class="{% if current_route == 'dashboard_agricole' %}active{% endif %}">
                    <i class="fa-solid fa-house"></i>
                    <span>Tableau de bord</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="#" onclick="openProfileModal(); return false;">
                    <i class="fa-solid fa-user"></i>
                    <span>Mon Profil</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('app_exploitation_menu') }}" class="{% if current_route == 'app_exploitation_menu' %}active{% endif %}">
                    <i class="fa-solid fa-tractor"></i>
                    <span>Mon Exploitation</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="#">
                    <i class="fa-solid fa-lightbulb"></i>
                    <span>Recommandations</span>
                </a>
            </li>
        </ul>

        <div class="logout-container">
            <a href="{{ path('app_logout') }}">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                <span>Déconnexion</span>
            </a>
        </div>
    </aside>

    <main class="main-content">
        <header class="topbar">
            <div class="brand-title">FarmAI Platform</div>
            <div class="topbar-right">
                <div class="topbar-avatar" style="display: flex; align-items: center; justify-content: center; cursor: pointer; overflow: hidden; border-radius: 50%;" onclick="openProfileModal()">
                    {% include 'components/_avatar.html.twig' with {'user': app.user, 'size': '100%', 'fontSize': '1rem'} %}
                </div>
            </div>
        </header>

        {% block body %}{% endblock %}
    </main>

    <div class="translate-floating-btn">
        <i class="fa-solid fa-language"></i>
        <div id="google_translate_element"></div>
    </div>

    {% include 'components/_profile_modal.html.twig' %}
    
    {% block javascripts %}
        <script type="text/javascript">
            function googleTranslateElementInit() {
                new google.translate.TranslateElement({
                    pageLanguage: 'fr', 
                    includedLanguages: 'en,ar,es,it,de', 
                    layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
                    autoDisplay: false
                }, 'google_translate_element');
            }
        </script>
        <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    {% endblock %}
</body>
</html>