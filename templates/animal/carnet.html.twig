{% extends 'layouts/agricole.html.twig' %}

{% block title %}Carnet de Santé - {{ animal.espece }}{% endblock %}

{% block body %}
<div style="background: #f1f5f9; min-height: 100vh; padding: 40px; font-family: 'Inter', sans-serif;">
    
    {# --- HEADER --- #}
    <div style="max-width: 1000px; margin: 0 auto 30px; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <a href="{{ path('app_animal_index') }}" style="text-decoration: none; color: #64748b; font-weight: 600; font-size: 0.9rem;">
                <i class="fa-solid fa-chevron-left"></i> Retour au cheptel
            </a>
            <h1 style="margin: 10px 0 0; color: #1e293b; font-size: 1.8rem;">Carnet de Santé Numérique</h1>
        </div>
        <div style="display: flex; gap: 10px;">
             <a href="{{ path('app_animal_consultation', {id_animal: animal.idAnimal}) }}" style="background: #059669; color: white; text-decoration: none; padding: 12px 20px; border-radius: 10px; font-weight: 700; font-size: 0.9rem; box-shadow: 0 4px 10px rgba(5, 150, 105, 0.2);">
                <i class="fa-solid fa-plus"></i> Nouveau Diagnostic IA
            </a>
        </div>
    </div>

    <div style="max-width: 1000px; margin: auto; display: grid; grid-template-columns: 300px 1fr; gap: 40px;">
        
        {# --- FICHE D'IDENTITÉ --- #}
        <div style="position: sticky; top: 40px; height: fit-content;">
            <div style="background: white; border-radius: 24px; padding: 30px; border: 1px solid #e2e8f0; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05); text-align: center;">
                <div style="width: 80px; height: 80px; background: #f8fafc; border: 2px solid #e2e8f0; color: #1e293b; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px; font-size: 2rem;">
                    <i class="fa-solid fa-cow"></i>
                </div>
                <h2 style="margin: 0; color: #1e293b; text-transform: capitalize;">{{ animal.espece }}</h2>
                <span style="display: inline-block; background: #f1f5f9; color: #475569; padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; margin-top: 8px;">ID #{{ animal.idAnimal }}</span>
                
                <div style="margin-top: 25px; text-align: left; border-top: 1px solid #f1f5f9; padding-top: 20px;">
                    <div style="margin-bottom: 15px;">
                        <small style="color: #94a3b8; display: block; text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">État de santé</small>
                        <b style="color: {{ animal.etatSante == 'Sain' ? '#059669' : '#dc2626' }}; font-size: 1rem;">
                            <i class="fa-solid fa-circle" style="font-size: 0.6rem; vertical-align: middle; margin-right: 5px;"></i>
                            {{ animal.etatSante }}
                        </b>
                    </div>
                    <div style="margin-bottom: 15px;">
                        <small style="color: #94a3b8; display: block; text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">Lieu de résidence</small>
                        <b style="color: #1e293b;">{{ animal.ferme ? animal.ferme.nomFerme : 'Non assigné' }}</b>
                    </div>
                    <div>
                        <small style="color: #94a3b8; display: block; text-transform: uppercase; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em;">Âge enregistré</small>
                        <b style="color: #1e293b;">{{ animal.dateNaissance ? animal.dateNaissance|date('d/m/Y') : 'Inconnu' }}</b>
                    </div>
                </div>
            </div>
        </div>

        {# --- LISTE DES INTERVENTIONS --- #}
        <div>
            {% if historique is empty %}
                <div style="background: white; border-radius: 24px; padding: 60px; text-align: center; border: 2px dashed #cbd5e1;">
                    <i class="fa-solid fa-notes-medical" style="font-size: 3rem; color: #cbd5e1; margin-bottom: 20px;"></i>
                    <h3 style="color: #64748b;">Aucun historique médical</h3>
                    <p style="color: #94a3b8;">Lancez une consultation IA pour commencer le suivi.</p>
                </div>
            {% else %}
                {% for suivi in historique %}
                    <div style="display: flex; gap: 20px; margin-bottom: 30px; position: relative;">
                        {# Ligne de timeline #}
                        {% if not loop.last %}
                        <div style="position: absolute; left: 25px; top: 50px; bottom: -40px; width: 2px; background: #e2e8f0;"></div>
                        {% endif %}

                        {# Point sur la timeline #}
                        <div style="width: 52px; height: 52px; background: white; border: 2px solid #059669; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 1; flex-shrink: 0; color: #059669; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                            <i class="fa-solid fa-stethoscope"></i>
                        </div>

                        {# Carte d'info #}
                        <div style="background: white; border-radius: 20px; padding: 25px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.02); flex-grow: 1; position: relative;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                                <div>
                                    <span style="color: #1e293b; font-weight: 800; font-size: 1.1rem;">Analyse FarmAI</span>
                                    <span style="display: block; color: #94a3b8; font-size: 0.8rem; font-weight: 600;">
                                        {{ suivi.dateConsultation|date('d F Y à H:i') }}
                                    </span>
                                </div>
                                <span style="background: #f8fafc; border: 1px solid #e2e8f0; color: #475569; padding: 5px 12px; border-radius: 8px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase;">
                                    Statut : {{ suivi.etatAuMoment }}
                                </span>
                            </div>

                            <div style="background: #f8fafc; border-radius: 12px; padding: 20px; color: #334155; line-height: 1.6; font-size: 0.95rem; border-left: 4px solid #059669;">
                                {{ suivi.diagnostic|nl2br }}
                            </div>
                            
                            <div style="margin-top: 15px; display: flex; align-items: center; gap: 10px; color: #64748b; font-size: 0.8rem;">
                                <i class="fa-solid fa-shield-halved" style="color: #059669;"></i>
                                Archivage certifié FarmAI - Diagnostic n°{{ suivi.id }}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
</style>
{% endblock %}