<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Registre du Cheptel</title>
    <style>
        body { font-family: sans-serif; font-size: 12px; color: #333; }
        h1 { color: #2d7a36; text-align: center; border-bottom: 2px solid #2d7a36; padding-bottom: 10px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 10px; text-align: left; }
        th { background-color: #f1f5f9; color: #1e293b; font-weight: bold; }
        .footer { margin-top: 30px; text-align: right; font-style: italic; font-size: 10px; }
    </style>
</head>
<body>
    <h1>FarmAI - Registre du Cheptel</h1>
    <p>Document généré le : {{ "now"|date("d/m/Y H:i") }}</p>

    <table>
        <thead>
            <tr>
                <th>Espèce</th>
                <th>État de Santé</th>
                <th>Date de Naissance</th>
            </tr>
        </thead>
        <tbody>
            {# Utilisation de "animals" pour correspondre au contrôleur #}
            {% for animal in animals %}
                <tr>
                    <td>{{ animal.espece }}</td>
                    <td>{{ animal.etatSante }}</td>
                    <td>{{ animal.dateNaissance ? animal.dateNaissance|date('d/m/Y') : 'N/A' }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" style="text-align: center;">Aucun animal enregistré.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="footer">
        © 2026 FarmAI - Système de Gestion Agricole Intelligent
    </div>
</body>
</html>