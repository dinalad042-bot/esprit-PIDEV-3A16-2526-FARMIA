{% extends 'layouts/agricole.html.twig' %}

{% block body %}
<div style="padding: 40px; background: #f1f5f9; min-height: 100vh; font-family: sans-serif;">
    <div style="max-width: 700px; margin: auto; background: white; padding: 30px; border-radius: 20px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);">
        
        <a href="{{ path('app_animal_index') }}" style="color: #64748b; text-decoration: none; font-size: 0.9rem;">← Retour à la liste</a>
        
        <h2 style="margin-top: 20px; color: #1e293b;">Diagnostic Expert : {{ animal.espece }}</h2>
        <p style="color: #64748b;">Analyse des symptômes par intelligence artificielle.</p>

        <form method="POST" onsubmit="document.getElementById('loader').style.display='block';">
            <label style="display: block; margin-bottom: 8px; font-weight: bold;">Observations de l'agriculteur :</label>
            <textarea name="description" required placeholder="Décrivez le comportement de l'animal..." 
                style="width: 100%; height: 120px; border-radius: 10px; border: 1px solid #cbd5e1; padding: 15px; margin-bottom: 15px;"></textarea>
            
            <button type="submit" style="width: 100%; background: #059669; color: white; border: none; padding: 12px; border-radius: 10px; font-weight: bold; cursor: pointer;">
                Consulter l'IA FarmAI
            </button>
        </form>

        <div id="loader" style="display:none; text-align: center; margin-top: 15px; color: #059669;">
            <i class="fas fa-spinner fa-spin"></i> Analyse en cours...
        </div>

        {% if reponseIA %}
            <div style="margin-top: 25px; padding: 20px; background: #ecfdf5; border-radius: 15px; border-left: 5px solid #059669;">
                <h4 style="margin: 0 0 10px 0; color: #065f46;">Résultat de l'analyse :</h4>
                <div style="color: #1e293b; line-height: 1.6; white-space: pre-wrap;">{{ reponseIA }}</div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}