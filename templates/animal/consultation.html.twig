{% extends 'layouts/agricole.html.twig' %}

{% block title %}Diagnostic Expert - FarmAI{% endblock %}

{% block body %}
<div style="background-color: #f8fafc; min-height: 100vh; padding: 40px; font-family: 'Plus Jakarta Sans', sans-serif;">
    
    {# --- RETOUR --- #}
    <div style="max-width: 900px; margin: 0 auto 20px;">
        <a href="{{ path('app_animal_index') }}" style="text-decoration: none; color: #64748b; font-weight: 600; display: flex; align-items: center; gap: 8px;">
            <i class="fa-solid fa-arrow-left"></i> Retour à la gestion du bétail
        </a>
    </div>

    <div style="max-width: 900px; margin: auto; display: grid; grid-template-columns: 1fr 2fr; gap: 30px;">
        
        {# --- INFOS ANIMAL --- #}
        <div style="background: white; border-radius: 20px; padding: 25px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; height: fit-content;">
            <div style="text-align: center; margin-bottom: 20px;">
                <div style="width: 60px; height: 60px; background: #f0fdf4; color: #2d7a36; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 10px; font-size: 1.5rem;">
                    <i class="fa-solid fa-cow"></i>
                </div>
                <h3 style="margin: 0; color: #1e293b;">{{ animal.espece }}</h3>
                <p style="font-size: 0.8rem; color: #64748b;">ID : #{{ animal.idAnimal }}</p>
            </div>
            
            <div style="font-size: 0.9rem; color: #475569;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                    <span>État actuel :</span>
                    <b style="color: #dc2626;">{{ animal.etatSante }}</b>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span>Ferme :</span>
                    <b>{{ animal.ferme ? animal.ferme.nomFerme : 'N/A' }}</b>
                </div>
            </div>
        </div>

        {# --- ZONE DE DIAGNOSTIC --- #}
        <div style="background: white; border-radius: 20px; padding: 35px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); border: 1px solid #e2e8f0;">
            <h2 style="margin: 0 0 10px 0; color: #1e293b; display: flex; align-items: center; gap: 10px;">
                <i class="fa-solid fa-robot" style="color: #059669;"></i> 
                Assistant Vétérinaire IA
            </h2>
            <p style="color: #64748b; margin-bottom: 25px;">Décrivez les symptômes pour obtenir une analyse et l'archiver.</p>

            {# FORMULAIRE 1 : CONSULTER L'IA #}
            <form method="POST" onsubmit="document.getElementById('loader').style.display='flex'; document.getElementById('btn-analyze').style.display='none';">
                <label style="display: block; margin-bottom: 8px; font-weight: 700; color: #1e293b; font-size: 0.9rem;">Observations :</label>
                <textarea name="description" required placeholder="Ex: L'animal ne mange plus et semble léthargique depuis ce matin..." 
                    style="width: 100%; height: 120px; border-radius: 12px; border: 1px solid #cbd5e1; padding: 15px; margin-bottom: 20px; font-family: inherit; resize: none; font-size: 1rem; outline-color: #059669;">{{ app.request.request.get('description') }}</textarea>
                
                {# AJOUT CRUCIAL : Le champ action pour le contrôleur #}
                <input type="hidden" name="action" value="get_analysis">

                {% if not reponseIA %}
                    <button type="submit" id="btn-analyze" style="width: 100%; background: #059669; color: white; border: none; padding: 15px; border-radius: 12px; font-weight: 800; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; transition: 0.3s;">
                        <i class="fa-solid fa-wand-magic-sparkles"></i> Analyser avec FarmAI
                    </button>
                {% endif %}
            </form>

            {# LOADER #}
            <div id="loader" style="display:none; align-items: center; justify-content: center; gap: 10px; margin-top: 20px; color: #059669; font-weight: 700;">
                <i class="fas fa-spinner fa-spin"></i> Intelligence Artificielle en action...
            </div>

            {# RÉSULTAT ET ENREGISTREMENT DÉFINITIF #}
            {% if reponseIA %}
                <div style="margin-top: 30px; padding: 25px; background: #f0fdf4; border-radius: 15px; border: 1px solid #bbf7d0; position: relative;">
                    <h4 style="margin: 0 0 12px 0; color: #166534; display: flex; align-items: center; gap: 8px;">
                        <i class="fa-solid fa-clipboard-check"></i> Diagnostic suggéré :
                    </h4>
                    <div style="color: #1e293b; line-height: 1.6; white-space: pre-wrap; font-size: 0.95rem; margin-bottom: 20px;">{{ reponseIA }}</div>

                    {# FORMULAIRE 2 : SAUVEGARDER DANS L'HISTORIQUE #}
                    <form method="POST">
                        <input type="hidden" name="diagnostic_ia" value="{{ reponseIA }}">
                        <input type="hidden" name="action" value="save_history">
                        
                        <button type="submit" style="width: 100%; background: #1e293b; color: white; border: none; padding: 15px; border-radius: 12px; font-weight: 800; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; transition: 0.3s;">
                            <i class="fa-solid fa-box-archive"></i> Enregistrer dans le carnet de santé
                        </button>
                    </form>
                    
                    <a href="{{ path('app_animal_consultation', {'id_animal': animal.idAnimal}) }}" style="display: block; text-align: center; margin-top: 15px; color: #64748b; font-size: 0.85rem; text-decoration: none;">
                        <i class="fa-solid fa-rotate-left"></i> Recommencer l'analyse
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}